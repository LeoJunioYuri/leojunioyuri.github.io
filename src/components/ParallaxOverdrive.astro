---
// Liquid-glass orbs — visible only during the "parallax" easter egg overdrive.
---

<div id="parallax-overdrive-layer" aria-hidden="true">
  <div class="lg-orb"></div>
  <div class="lg-orb"></div>
  <div class="lg-orb"></div>
  <div class="lg-orb"></div>
  <div class="lg-orb"></div>
</div>

<style is:global>
  #parallax-overdrive-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 49;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .parallax-overdrive #parallax-overdrive-layer {
    opacity: 1;
  }

  .lg-orb {
    position: absolute;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 70%;
    backdrop-filter: blur(28px) saturate(180%) brightness(1.04);
    -webkit-backdrop-filter: blur(28px) saturate(180%) brightness(1.04);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.04) 55%,
      rgba(255, 255, 255, 0.10) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.30);
    box-shadow:
      inset 0 1.5px 0 rgba(255, 255, 255, 0.55),
      inset 0 -1px 0 rgba(0, 0, 0, 0.04),
      0 12px 48px rgba(0, 0, 0, 0.08);
    will-change: transform, border-radius;
    animation: lg-morph var(--dur, 10s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  /* Specular highlight — bright spot that makes it look like glass catching light */
  .lg-orb::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 28% 22%,
      rgba(255, 255, 255, 0.42) 0%,
      rgba(255, 255, 255, 0.08) 40%,
      transparent 65%
    );
  }

  /* Iridescent tint — garnet + blue + violet like glass prism */
  .lg-orb::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      135deg,
      rgba(156, 31, 51, 0.07) 0%,
      rgba(90, 160, 255, 0.06) 50%,
      rgba(160, 90, 255, 0.06) 100%
    );
    animation: lg-iridescent var(--dur, 10s) ease-in-out infinite alternate;
    animation-delay: var(--delay, 0s);
  }

  /* Dark mode glass */
  .dark .lg-orb {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.09) 0%,
      rgba(255, 255, 255, 0.02) 55%,
      rgba(255, 255, 255, 0.06) 100%
    );
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow:
      inset 0 1.5px 0 rgba(255, 255, 255, 0.22),
      0 12px 48px rgba(0, 0, 0, 0.35);
  }
  .dark .lg-orb::after {
    background: linear-gradient(
      135deg,
      rgba(224, 117, 138, 0.10) 0%,
      rgba(90, 160, 255, 0.07) 50%,
      rgba(160, 90, 255, 0.07) 100%
    );
  }

  @keyframes lg-morph {
    0%,  100% { border-radius: 60% 40% 70% 30% / 50% 60% 40% 70%; }
    20%       { border-radius: 45% 55% 35% 65% / 65% 35% 65% 35%; }
    40%       { border-radius: 70% 30% 50% 50% / 30% 70% 50% 50%; }
    60%       { border-radius: 35% 65% 60% 40% / 55% 45% 55% 45%; }
    80%       { border-radius: 55% 45% 40% 60% / 40% 60% 60% 40%; }
  }

  @keyframes lg-iridescent {
    from { opacity: 0.6; filter: hue-rotate(0deg); }
    to   { opacity: 1;   filter: hue-rotate(30deg); }
  }
</style>

<script>
  const layer = document.getElementById("parallax-overdrive-layer");

  if (layer) {
    const orbs = Array.from(layer.querySelectorAll<HTMLElement>(".lg-orb"));

    const CONFIG = [
      { x: 0.12, y: 0.14, w: 340, h: 270, spd: 0.006, dur: 11,  delay: 0    },
      { x: 0.70, y: 0.52, w: 260, h: 320, spd: 0.007, dur: 9,   delay: -2.5 },
      { x: 0.44, y: 0.74, w: 400, h: 250, spd: 0.005, dur: 13,  delay: -5   },
      { x: 0.82, y: 0.20, w: 220, h: 220, spd: 0.008, dur: 8,   delay: -1.5 },
      { x: 0.24, y: 0.62, w: 300, h: 360, spd: 0.006, dur: 10,  delay: -3.5 },
    ];

    // Apply fixed styles
    CONFIG.forEach((c, i) => {
      const el = orbs[i];
      el.style.width  = c.w + "px";
      el.style.height = c.h + "px";
      el.style.setProperty("--dur",   c.dur   + "s");
      el.style.setProperty("--delay", c.delay + "s");
    });

    type State = { x: number; y: number; tx: number; ty: number };
    const states: State[] = CONFIG.map(c => ({ x: c.x, y: c.y, tx: c.x, ty: c.y }));

    let px = 0, py = 0;
    document.addEventListener("mousemove", (e) => {
      px = (e.clientX / window.innerWidth  - 0.5) * 2;
      py = (e.clientY / window.innerHeight - 0.5) * 2;
    }, { passive: true });

    function pickTarget(s: State) {
      s.tx = 0.06 + Math.random() * 0.88;
      s.ty = 0.06 + Math.random() * 0.88;
    }
    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    let rafId = 0, active = false;

    function tick() {
      if (!active) return;

      states.forEach((s, i) => {
        const c = CONFIG[i];

        // Float toward target + subtle mouse pull
        const etx = s.tx + px * 0.05;
        const ety = s.ty + py * 0.03;

        s.x = lerp(s.x, etx, c.spd);
        s.y = lerp(s.y, ety, c.spd);

        if (Math.abs(s.x - s.tx) < 0.01 && Math.abs(s.y - s.ty) < 0.01) {
          pickTarget(s);
        }

        const sx = s.x * window.innerWidth  - c.w / 2;
        const sy = s.y * window.innerHeight - c.h / 2;
        orbs[i].style.transform = `translate(${sx}px, ${sy}px)`;
      });

      rafId = requestAnimationFrame(tick);
    }

    new MutationObserver(() => {
      const on = document.documentElement.classList.contains("parallax-overdrive");
      if (on && !active) {
        active = true;
        states.forEach(s => pickTarget(s));
        rafId = requestAnimationFrame(tick);
      } else if (!on && active) {
        active = false;
        cancelAnimationFrame(rafId);
      }
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });
  }
</script>
