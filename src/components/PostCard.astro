---
import type { Lang } from "@/consts";
import { useTranslations, localizedPath, formatDate } from "@/i18n/utils";
import {
  categoryLabel,
  categoryColor,
  type Category,
} from "@/i18n/categories";

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  date: Date;
  category: Category;
  tags: string[];
  readingTime: number;
  pinned?: boolean;
  draft?: boolean;
}
const {
  lang,
  slug,
  title,
  description,
  date,
  category,
  tags,
  readingTime,
  pinned,
  draft,
} = Astro.props;
const t = useTranslations(lang);
const href = localizedPath(lang, `writing/${slug}`);
const color = categoryColor[category];
---

<article class="group" data-post data-category={category}>
  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-xs">
    <span
      class="rounded-full border px-2.5 py-0.5 font-medium"
      style={`color:${color};border-color:${color}55;background:${color}14`}
    >
      {categoryLabel[lang][category]}
    </span>
    <span class="text-[var(--muted)]">
      <time datetime={date.toISOString()}>{formatDate(date, lang)}</time>
      <span aria-hidden="true"> · </span>
      <span>{readingTime} {t("writing.readingTime")}</span>
    </span>
    {
      draft && (
        <span class="rounded bg-[var(--accent-soft)] px-1.5 py-0.5 font-medium text-[var(--accent)]">
          {t("writing.draft")}
        </span>
      )
    }
  </div>

  <a href={href} class="mt-2 block">
    <h3
      class="text-xl font-semibold tracking-tight transition-colors group-hover:text-[var(--accent)]"
    >
      {title}
    </h3>
    <p class="mt-2 text-[var(--muted)]">{description}</p>
  </a>

  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li class="rounded-md border border-[var(--border)] px-2 py-0.5 text-xs text-[var(--muted)]">
            {tag}
          </li>
        ))}
      </ul>
    )
  }
</article>
