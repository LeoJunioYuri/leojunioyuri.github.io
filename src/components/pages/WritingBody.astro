---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { useTranslations, readingTime } from "@/i18n/utils";
import { getPosts, slugOf } from "@/content-utils";
import { CATEGORIES, categoryLabel } from "@/i18n/categories";
import type { Lang } from "@/consts";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = await getPosts(lang);
const pinned = posts.filter((p) => p.data.pinned);
const present = CATEGORIES.filter((c) =>
  posts.some((p) => p.data.category === c),
);

const path = lang === "pt" ? "/writing" : "/en/writing";
---

<BaseLayout
  lang={lang}
  title={t("writing.title")}
  description={t("writing.subtitle")}
  path={path}
>
  <section class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      {t("writing.title")}
    </h1>
    <p class="mt-3 max-w-xl text-lg text-[var(--muted)]">
      {t("writing.subtitle")}
    </p>

    {
      pinned.length > 0 && (
        <div class="mt-12">
          <h2 class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-[var(--muted)]">
            <svg
              class="h-4 w-4 text-[var(--accent)]"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="m12 2 2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7z" />
            </svg>
            {t("writing.startHere")}
          </h2>
          <div data-reveal-scroll class="mt-5 grid gap-5 rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 sm:p-7">
            {pinned.map((p) => (
              <PostCard
                lang={lang}
                slug={slugOf(p.id)}
                title={p.data.title}
                description={p.data.description}
                date={p.data.date}
                category={p.data.category}
                tags={p.data.tags}
                readingTime={readingTime(p.body ?? "")}
                pinned={p.data.pinned}
                draft={p.data.draft}
              />
            ))}
          </div>
        </div>
      )
    }

    {
      present.length > 1 && (
        <div
          id="filters"
          class="mt-14 flex flex-wrap gap-2"
          role="group"
          aria-label={t("writing.title")}
        >
          <button
            type="button"
            data-filter="all"
            aria-pressed="true"
            class="filter-chip rounded-full border border-[var(--border)] px-3 py-1 text-sm font-medium text-[var(--muted)] transition-colors aria-pressed:border-[var(--accent)] aria-pressed:bg-[var(--accent)] aria-pressed:text-[var(--accent-fg)]"
          >
            {t("writing.filterAll")}
          </button>
          {present.map((c) => (
            <button
              type="button"
              data-filter={c}
              aria-pressed="false"
              class="filter-chip rounded-full border border-[var(--border)] px-3 py-1 text-sm font-medium text-[var(--muted)] transition-colors aria-pressed:border-[var(--accent)] aria-pressed:bg-[var(--accent)] aria-pressed:text-[var(--accent-fg)]"
            >
              {categoryLabel[lang][c]}
            </button>
          ))}
        </div>
      )
    }

    <div id="post-list" class="mt-10 flex flex-col gap-12">
      {
        posts.length === 0 ? (
          <p class="text-[var(--muted)]">{t("writing.empty")}</p>
        ) : (
          posts.map((p) => (
            <PostCard
              lang={lang}
              slug={slugOf(p.id)}
              title={p.data.title}
              description={p.data.description}
              date={p.data.date}
              category={p.data.category}
              tags={p.data.tags}
              readingTime={readingTime(p.body ?? "")}
              pinned={p.data.pinned}
              draft={p.data.draft}
            />
          ))
        )
      }
      <p id="empty-filter" hidden class="text-[var(--muted)]">
        {t("writing.empty.filter")}
      </p>
    </div>
  </section>

  <script>
    const buttons =
      document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const list = document.getElementById("post-list");
    const posts = list?.querySelectorAll<HTMLElement>("[data-post]") ?? [];
    const empty = document.getElementById("empty-filter");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.getAttribute("data-filter");
        buttons.forEach((b) =>
          b.setAttribute("aria-pressed", String(b === btn)),
        );
        let visible = 0;
        posts.forEach((post) => {
          const match =
            filter === "all" || post.getAttribute("data-category") === filter;
          post.hidden = !match;
          if (match) visible++;
        });
        if (empty) empty.hidden = visible !== 0;
      });
    });
  </script>
</BaseLayout>
