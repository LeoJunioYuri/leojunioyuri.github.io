---
import type { Lang } from "@/consts";
import { useTranslations } from "@/i18n/utils";
import Architecture from "@/components/diagrams/Architecture.astro";
import CampaignLoop from "@/components/diagrams/CampaignLoop.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const cases = [
  {
    n: "01",
    title: t("case.platform.title"),
    desc: t("case.platform.desc"),
    points: t("case.platform.points") as readonly string[],
  },
  {
    n: "02",
    title: t("case.ai.title"),
    desc: t("case.ai.desc"),
    points: t("case.ai.points") as readonly string[],
  },
  {
    n: "03",
    title: t("case.data.title"),
    desc: t("case.data.desc"),
    points: t("case.data.points") as readonly string[],
  },
];
---

<section id="work" class="mx-auto max-w-3xl scroll-mt-20 px-5 py-20 sm:px-6">
  <h2 data-reveal-scroll class="text-2xl font-bold tracking-tight sm:text-3xl">
    {t("work.title")}
  </h2>
  <p data-reveal-scroll class="mt-2 max-w-xl text-[var(--muted)]">
    {t("work.subtitle")}
  </p>

  <div class="mt-10 flex flex-col gap-4">
    {
      cases.map((c, i) => (
        <article
          data-reveal-scroll
          style={`transition-delay:${i * 90}ms`}
          class="group rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 transition-colors hover:border-[var(--accent)] sm:p-7"
        >
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-sm text-[var(--accent)]">{c.n}</span>
            <h3 class="text-lg font-semibold tracking-tight sm:text-xl">
              {c.title}
            </h3>
          </div>
          <p class="mt-3 text-[var(--muted)]">{c.desc}</p>
          <ul class="mt-4 grid gap-2 sm:grid-cols-3">
            {c.points.map((p) => (
              <li class="flex items-start gap-2 text-sm">
                <svg
                  class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M20 6 9 17l-5-5" />
                </svg>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>

  <div class="mt-8 grid gap-4">
    <Architecture lang={lang} />
    <CampaignLoop lang={lang} />
  </div>
</section>
