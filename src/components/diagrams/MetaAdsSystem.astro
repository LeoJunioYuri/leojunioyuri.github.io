---
import type { Lang } from "@/consts";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const pt = lang === "pt";

const T = {
  pt: {
    eyebrow:    "MetaAds — sistema em 30 segundos",
    dono:       "Dono",
    donoSub:    "restaurante",
    platform:   "Plataforma",
    p1:         "painel · criativos",
    p2:         "investimento · config",
    andSub:     "Gestor de Tráfego com IA",
    cycle1:     "Observa · Delibera · Valida",
    cycle2:     "Aplica · Reporta",
    meta1:      "campanhas · orçamento",
    meta2:      "pixel · CAPI",
    result:     "Pedidos",
    resultSub:  "ROAS · CPO",
    feedback:   "ROAS real alimenta o próximo ciclo",
  },
  en: {
    eyebrow:    "MetaAds — system in 30 seconds",
    dono:       "Owner",
    donoSub:    "restaurant",
    platform:   "Platform",
    p1:         "dashboard · creatives",
    p2:         "investment · settings",
    andSub:     "AI Traffic Manager",
    cycle1:     "Observe · Deliberate · Validate",
    cycle2:     "Apply · Report",
    meta1:      "campaigns · budget",
    meta2:      "pixel · CAPI",
    result:     "Orders",
    resultSub:  "ROAS · CPO",
    feedback:   "real ROAS feeds the next cycle",
  },
};

const t = pt ? T.pt : T.en;
---

<figure class="overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)]">
  <figcaption class="border-b border-[var(--border)] px-4 py-2.5 text-xs font-medium uppercase tracking-wide text-[var(--muted)]">
    {t.eyebrow}
  </figcaption>
  <div class="overflow-x-auto p-4 sm:p-6">
    <svg viewBox="0 0 860 240" fill="none" xmlns="http://www.w3.org/2000/svg"
      class="h-auto w-full" style="min-width:560px; color: var(--fg);">
      <defs>
        <marker id="mas-arr" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M0,1.5 L6.5,4 L0,6.5 Z" fill="var(--border)"/>
        </marker>
        <marker id="mas-arr-loop" viewBox="0 0 8 8" refX="7" refY="4" markerWidth="5" markerHeight="5" orient="auto">
          <path d="M0,1.5 L6.5,4 L0,6.5 Z" fill="var(--accent)"/>
        </marker>
      </defs>

      <style>
        .mas-box   { fill: var(--bg); stroke: var(--border); stroke-width: 1.2; }
        .mas-hero  { fill: var(--accent-soft); stroke: var(--accent); stroke-width: 1.5; }
        .mas-title { fill: var(--fg);    font: 600 12.5px var(--font-sans, sans-serif); }
        .mas-sub   { fill: var(--muted); font: 400 10px   var(--font-sans, sans-serif); }
        .mas-brand { fill: var(--accent); font: 700 12px  var(--font-sans, sans-serif); letter-spacing: 0.07em; }
        .mas-cycle { fill: var(--fg);    font: 400 10px   var(--font-sans, sans-serif); opacity: 0.75; }
        .mas-roas  { fill: var(--accent); font: 700 13px  var(--font-sans, sans-serif); opacity: 0.85; }
        .mas-flow  { stroke: var(--border); stroke-width: 1.4; fill: none; marker-end: url(#mas-arr); }
        .mas-feed  { stroke: var(--accent); stroke-width: 1.4; stroke-dasharray: 4.5 3.5; fill: none;
                     marker-end: url(#mas-arr-loop); opacity: 0.35; }
        .mas-divider { stroke: var(--border); stroke-width: 0.8; opacity: 0.5; }
        .mas-feedback-lbl { fill: var(--accent); font: italic 9.5px var(--font-sans, sans-serif); opacity: 0.5; }
      </style>

      <!-- Dono -->
      <rect class="mas-box" x="8" y="107" width="100" height="56" rx="7"/>
      <text class="mas-title" x="58" y="131" text-anchor="middle">{t.dono}</text>
      <text class="mas-sub"   x="58" y="148" text-anchor="middle">{t.donoSub}</text>

      <line class="mas-flow" x1="108" y1="135" x2="143" y2="135"/>

      <!-- Plataforma -->
      <rect class="mas-box" x="146" y="95" width="152" height="80" rx="7"/>
      <text class="mas-title" x="222" y="117" text-anchor="middle">{t.platform}</text>
      <text class="mas-sub"   x="222" y="134" text-anchor="middle">{t.p1}</text>
      <text class="mas-sub"   x="222" y="150" text-anchor="middle">{t.p2}</text>

      <line class="mas-flow" x1="298" y1="135" x2="336" y2="135"/>

      <!-- Anderson (hero) -->
      <rect class="mas-hero" x="339" y="85" width="228" height="100" rx="9"/>
      <text class="mas-brand" x="453" y="107" text-anchor="middle">ANDERSON</text>
      <text class="mas-sub"   x="453" y="122" text-anchor="middle" style="opacity:0.6">{t.andSub}</text>
      <line class="mas-divider" x1="359" y1="131" x2="547" y2="131"/>
      <text class="mas-cycle" x="453" y="149" text-anchor="middle">{t.cycle1}</text>
      <text class="mas-cycle" x="453" y="165" text-anchor="middle">{t.cycle2}</text>

      <line class="mas-flow" x1="567" y1="135" x2="602" y2="135"/>

      <!-- Meta Ads -->
      <rect class="mas-box" x="605" y="100" width="130" height="70" rx="7"/>
      <text class="mas-title" x="670" y="122" text-anchor="middle">Meta Ads</text>
      <text class="mas-sub"   x="670" y="139" text-anchor="middle">{t.meta1}</text>
      <text class="mas-sub"   x="670" y="155" text-anchor="middle">{t.meta2}</text>

      <line class="mas-flow" x1="735" y1="135" x2="752" y2="135"/>

      <!-- Pedidos -->
      <rect class="mas-box" x="755" y="100" width="97" height="70" rx="7"/>
      <text class="mas-title" x="803" y="122" text-anchor="middle">{t.result}</text>
      <text class="mas-sub"   x="803" y="139" text-anchor="middle">{t.resultSub}</text>
      <text class="mas-roas"  x="803" y="157" text-anchor="middle">~10×</text>

      <!-- Feedback loop -->
      <path class="mas-feed" d="M670,170 C670,222 453,222 453,185"/>
      <text class="mas-feedback-lbl" x="562" y="234" text-anchor="middle">{t.feedback}</text>
    </svg>
  </div>

  <!-- Stack strip -->
  <div class="border-t border-[var(--border)] px-4 py-3 sm:px-6">
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
      <span class="text-[10px] font-semibold uppercase tracking-widest text-[var(--border)]">Stack</span>
      {[
        "TypeScript · Node.js", "GCP · Cloud Functions", "Postgres · pgvector",
        "Cloud Tasks · PubSub", "Meta Marketing API · CAPI", "OpenAI · Vertex AI",
        "Kling · Veo · MimeClip", "Prisma · Sentry · PostHog", "Metabase · Replit",
      ].map(item => (
        <span class="text-[11px] text-[var(--muted)]">{item}</span>
      ))}
    </div>
  </div>
</figure>
