---
const data = [
  { date: 'fev/16', val: 52.9 }, { date: 'fev/23', val: 41.0 },
  { date: 'mar/02', val: 30.9 }, { date: 'mar/09', val: 48.1 },
  { date: 'mar/16', val: 41.2 }, { date: 'mar/23', val: 43.5 },
  { date: 'mar/30', val: 41.9 }, { date: 'abr/06', val: 33.9 },
  { date: 'abr/13', val: 31.4 }, { date: 'abr/20', val: 45.8 },
  { date: 'abr/27', val: 21.2 }, { date: 'mai/04', val: 19.5 },
  { date: 'mai/11', val: 20.0 }, { date: 'mai/18', val:  6.4 },
  { date: 'mai/25', val:  3.4 }, { date: 'jun/01', val:  5.7 },
  { date: 'jun/08', val:  2.2 }, { date: 'jun/15', val:  1.4 },
];
const max = 55;
---

<div class="not-prose my-6 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-5">
  <p class="mb-4 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
    % lojas desativadas por cohort de entrada
  </p>
  <div class="space-y-1.5">
    {data.map(d => {
      const pct = (d.val / max * 100).toFixed(1);
      const color = d.val < 10 ? 'var(--accent)' : d.val > 40 ? '#C43A2A' : '#E8A527';
      return (
        <div class="flex items-center gap-3">
          <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted);width:52px;flex-shrink:0">
            {d.date}
          </span>
          <div style="flex:1;height:14px;background:var(--bg);border:1px solid var(--border);position:relative;border-radius:2px;">
            <div style={`position:absolute;inset:0;width:${pct}%;background:${color};border-radius:2px;opacity:0.85;`} />
          </div>
          <span style={`font-family:var(--font-mono);font-size:11px;width:40px;flex-shrink:0;text-align:right;color:${color};font-weight:600;`}>
            {d.val.toFixed(1)}%
          </span>
        </div>
      );
    })}
  </div>
  <p class="mt-3 text-[10px] text-[var(--muted)]">
    🟡 pré-PMF (&gt;20%) · 🔴 crítico (&gt;40%) · 🟢 pós-PMF (&lt;10%)
  </p>
</div>
