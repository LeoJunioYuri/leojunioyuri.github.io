---
import type { Lang } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const bullets = t("case.bullets") as readonly string[];
---

<section id="work" class="mx-auto max-w-3xl scroll-mt-20 px-5 py-20 sm:px-6">
  <h2 data-reveal-scroll class="text-2xl font-bold tracking-tight sm:text-3xl">
    {t("work.title")}
  </h2>
  <p data-reveal-scroll class="mt-2 max-w-xl text-[var(--muted)]">
    {t("work.subtitle")}
  </p>

  <article
    data-reveal-scroll
    class="mt-8 rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 sm:p-8"
  >
    <div class="flex items-center gap-3">
      <span class="font-mono text-sm text-[var(--accent)]">Brendi</span>
      <h3 class="text-xl font-bold tracking-tight sm:text-2xl">
        {t("case.metaads.title")}
      </h3>
    </div>
    <p class="mt-3 max-w-2xl text-[var(--muted)]">{t("case.metaads.desc")}</p>

    <ul class="mt-5 grid gap-2 sm:grid-cols-2">
      {bullets.map((b) => (
        <li class="flex items-start gap-2 text-sm">
          <svg
            class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5" />
          </svg>
          <span>{b}</span>
        </li>
      ))}
    </ul>

    <div class="mt-6">
      <a
        href={lang === "pt" ? "/brendi" : "/en/brendi"}
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--border)] px-5 py-2.5 text-sm font-semibold text-[var(--fg)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
      >
        {t("work.cta")}
      </a>
    </div>
  </article>
</section>
