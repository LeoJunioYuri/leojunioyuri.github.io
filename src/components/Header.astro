---
import { SITE, type Lang } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
import ThemeToggle from "@/components/ThemeToggle.astro";
import LangToggle from "@/components/LangToggle.astro";

interface Props {
  lang: Lang;
  path: string;
}
const { lang, path } = Astro.props;
const t = useTranslations(lang);

const home = localizedPath(lang);
const norm = (p: string) => "/" + p.replace(/^\/+|\/+$/g, "");
const current = norm(path);
const links = [
  { href: localizedPath(lang, "brendi"), label: t("nav.brendi") },
  { href: localizedPath(lang, "writing"), label: t("nav.writing") },
  { href: `${home === "/" ? "" : home}/#about`, label: t("nav.about") },
  { href: localizedPath(lang, "life"), label: t("nav.life") },
  { href: localizedPath(lang, "now"), label: t("nav.now") },
].map((l) => ({
  ...l,
  // A page link is "current" when its path matches; hash links never are.
  active: !l.href.includes("#") && norm(l.href) === current,
}));
---

<header
  id="site-header"
  class="sticky top-0 z-40 border-b border-[var(--border)] bg-[var(--bg)]/75 backdrop-blur-md transition-shadow duration-300"
>
  <nav
    class="mx-auto flex h-16 max-w-3xl items-center justify-between px-5 sm:px-6"
    aria-label="Primary"
  >
    <a
      href={home}
      class="group flex items-center gap-2 font-semibold tracking-tight"
    >
      <img src="/favicon-light.png" alt="LB" width="36" height="36"
        class="h-9 w-9 rounded-full block dark:hidden" />
      <img src="/favicon.png" alt="LB" width="36" height="36"
        class="h-9 w-9 rounded-full hidden dark:block" />
      <span class="hidden sm:inline">{SITE.name}</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={l.active ? "page" : undefined}
                class:list={[
                  "rounded-md px-3 py-2 text-sm transition-colors hover:text-[var(--fg)]",
                  l.active
                    ? "font-semibold text-[var(--fg)]"
                    : "text-[var(--muted)]",
                ]}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="flex items-center gap-1">
        <LangToggle lang={lang} path={path} />
        <ThemeToggle lang={lang} />
        <button
          id="menu-btn"
          type="button"
          class="grid h-10 w-10 place-items-center rounded-md border border-[var(--border)] text-[var(--muted)] transition-colors hover:bg-[var(--surface)] hover:text-[var(--fg)] sm:hidden"
          aria-label="Menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <svg
            data-icon="open"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            data-icon="close"
            hidden
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu" hidden class="border-t border-[var(--border)] bg-[var(--bg)] sm:hidden">
    <ul class="mx-auto flex max-w-3xl flex-col gap-1 px-5 py-3">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={l.active ? "page" : undefined}
              class:list={[
                "block rounded-md px-3 py-2.5 text-base transition-colors hover:bg-[var(--surface)]",
                l.active
                  ? "font-semibold text-[var(--fg)]"
                  : "text-[var(--muted)]",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Apple-style nav: gains a subtle elevation once the page is scrolled.
  const header = document.getElementById("site-header");
  const onScroll = () =>
    header?.classList.toggle("is-scrolled", window.scrollY > 8);
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Accessible mobile menu.
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconOpen = btn?.querySelector<HTMLElement>('[data-icon="open"]');
  const iconClose = btn?.querySelector<HTMLElement>('[data-icon="close"]');

  const setOpen = (open: boolean) => {
    if (!menu || !btn) return;
    menu.hidden = !open;
    btn.setAttribute("aria-expanded", String(open));
    if (iconOpen) iconOpen.hidden = open;
    if (iconClose) iconClose.hidden = !open;
    if (open) menu.querySelector<HTMLElement>("a")?.focus();
  };

  btn?.addEventListener("click", () =>
    setOpen(btn.getAttribute("aria-expanded") !== "true"),
  );
  // Close when navigating, pressing Esc, or clicking outside.
  menu?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) setOpen(false);
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && btn?.getAttribute("aria-expanded") === "true") {
      setOpen(false);
      btn.focus();
    }
  });
  document.addEventListener("click", (e) => {
    if (
      btn?.getAttribute("aria-expanded") === "true" &&
      !header?.contains(e.target as Node)
    ) {
      setOpen(false);
    }
  });
  // Reset when resizing up to desktop.
  window.matchMedia("(min-width: 640px)").addEventListener("change", (e) => {
    if (e.matches) setOpen(false);
  });
</script>
