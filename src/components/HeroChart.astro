---
// Animated MetaAds growth bars — background decoration for the hero section.
// Data: active restaurants Oct/24 → Jun/26 (V1+V2 Supabase merged with V3 AlloyDB).
---

<canvas id="hero-chart" data-parallax="chart" aria-hidden="true" style="position:absolute;inset:0;"></canvas>

<script>
  const DATA: [string, number][] = [
    ['Out/24', 2],   ['Nov/24', 5],   ['Dez/24', 8],
    ['Jan/25', 20],  ['Fev/25', 40],  ['Mar/25', 80],
    ['Abr/25', 130], ['Mai/25', 200], ['Jun/25', 250],
    ['Jul/25', 316], ['Ago/25', 280], ['Set/25', 240],
    ['Out/25', 195], ['Nov/25', 168], ['Dez/25', 155],
    ['Jan/26', 148], ['Fev/26', 310], ['Mar/26', 360],
    ['Abr/26', 430], ['Mai/26', 570], ['Jun/26', 684],
  ];
  const MAX = 750;

  function accentRgb(): string {
    const hex = getComputedStyle(document.documentElement)
      .getPropertyValue('--accent').trim();
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `${r}, ${g}, ${b}`;
  }

  function draw(canvas: HTMLCanvasElement, progress: number) {
    // Use the section as the size reference — the canvas parent is the bg div
    // which is also inset-0, so section ≈ parent ≈ canvas layout size.
    const section = canvas.closest('section') as HTMLElement | null;
    const cssW = section?.offsetWidth || canvas.offsetWidth;
    const cssH = section?.offsetHeight || canvas.offsetHeight;
    if (!cssW || !cssH) return;

    const dpr = window.devicePixelRatio || 1;
    canvas.style.width  = cssW + 'px';
    canvas.style.height = cssH + 'px';
    canvas.width  = cssW * dpr;
    canvas.height = cssH * dpr;

    const ctx = canvas.getContext('2d')!;
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, cssW, cssH);

    const rgb = accentRgb();
    const n = DATA.length;
    const gap = 3;
    const barW = (cssW - gap * (n - 1)) / n;
    // Cap chart height so bars stay consistent across PT/EN (PT hero is taller).
    const chartH = Math.min(Math.round(cssH * 0.87), 620);
    const padT = cssH - chartH;

    DATA.forEach(([, v], i) => {
      const h = (v / MAX) * chartH * progress;
      const x = i * (barW + gap);
      const y = padT + chartH - h;

      let fill: string | CanvasGradient;
      if (v >= 400) {
        const g = ctx.createLinearGradient(0, y, 0, cssH);
        g.addColorStop(0, `rgba(${rgb}, 0.55)`);
        g.addColorStop(1, `rgba(${rgb}, 0.04)`);
        fill = g;
      } else if (v >= 100) {
        const g = ctx.createLinearGradient(0, y, 0, cssH);
        g.addColorStop(0, `rgba(${rgb}, 0.32)`);
        g.addColorStop(1, `rgba(${rgb}, 0.03)`);
        fill = g;
      } else {
        fill = `rgba(${rgb}, 0.14)`;
      }

      ctx.fillStyle = fill;
      ctx.beginPath();
      ctx.roundRect(x, y, barW, h, [2, 2, 0, 0]);
      ctx.fill();
    });

    // Fade bars out toward the top so they don't compete with content/buttons.
    // destination-out "erases" — transparent at bottom of fade zone, opaque at top.
    ctx.save();
    ctx.globalCompositeOperation = 'destination-out';
    const fadeEnd = cssH * 0.52;
    const mask = ctx.createLinearGradient(0, 0, 0, fadeEnd);
    mask.addColorStop(0, 'rgba(0,0,0,1)');
    mask.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = mask;
    ctx.fillRect(0, 0, cssW, fadeEnd);
    ctx.restore();
  }

  const canvas = document.getElementById('hero-chart') as HTMLCanvasElement | null;

  if (canvas) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    let animated = false;

    function run() {
      if (animated) return;
      animated = true;
      if (reduce) { draw(canvas!, 1); return; }
      let start = 0;
      const dur = 1800;
      function tick(ts: number) {
        if (!start) start = ts;
        const p = Math.min(1, (ts - start) / dur);
        draw(canvas!, 1 - Math.pow(1 - p, 3));
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    // Trigger on load — hero is always in the viewport on first paint.
    window.addEventListener('load', () => requestAnimationFrame(run));

    // Redraw on resize or theme toggle.
    window.addEventListener('resize', () => draw(canvas!, 1), { passive: true });
    new MutationObserver(() => draw(canvas!, 1)).observe(
      document.documentElement,
      { attributes: true, attributeFilter: ['class'] },
    );
  }
</script>
