---
import type { Lang } from "@/consts";
import { useTranslations } from "@/i18n/utils";
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { icon: "metal", title: t("interests.metal.title"), desc: t("interests.metal.desc") },
  { icon: "tkd", title: t("interests.tkd.title"), desc: t("interests.tkd.desc") },
  { icon: "intl", title: t("interests.intl.title"), desc: t("interests.intl.desc") },
  { icon: "writing", title: t("interests.writing.title"), desc: t("interests.writing.desc") },
];
---

<section class="border-t border-[var(--border)] bg-[var(--surface)]">
  <div class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
      {t("interests.title")}
    </h2>
    <p class="mt-2 max-w-xl text-[var(--muted)]">{t("interests.subtitle")}</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        items.map((item, i) => (
          <article
            data-reveal-scroll
            style={`transition-delay:${i * 80}ms`}
            class="rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-6"
          >
            <span
              class="grid h-10 w-10 place-items-center rounded-xl text-[var(--accent)]"
              style="background: var(--accent-soft)"
            >
              {item.icon === "metal" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 18V5l12-2v13" />
                  <circle cx="6" cy="18" r="3" />
                  <circle cx="18" cy="16" r="3" />
                </svg>
              )}
              {item.icon === "tkd" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 12 6-9 6 9" />
                  <path d="M4 21h16" />
                  <path d="M12 3v18" />
                </svg>
              )}
              {item.icon === "intl" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" />
                  <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" />
                </svg>
              )}
              {item.icon === "writing" && (
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 20h9" />
                  <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
                </svg>
              )}
            </span>
            <h3 class="mt-4 font-semibold tracking-tight">{item.title}</h3>
            <p class="mt-1 text-sm text-[var(--muted)]">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
