---
import { SITE } from "@/consts";

const title = "Resume — Leonardo Basso";
const description = "Product Engineer · Brendi · leojunioyuri.github.io";

const experiences = [
  {
    role: "Product Engineer · Founding Team",
    company: "Brendi",
    period: "Oct 2024 — present",
    location: "São José dos Campos, Brazil",
    bullets: [
      "Led the development of MetaAds, an autonomous paid-traffic platform for restaurants, scaling from 0 to 2,000+ active restaurants across Brendi's base — R$20M+ in attributed sales and average 10× ROAS.",
      "Served as primary engineer owning architecture, implementation and product evolution, eliminating all manual intervention in the financial flow with a custom billing layer managing R$500k+/month autonomously.",
      "Designed and implemented serverless APIs handling 10M+ requests/month, p95 < 200ms and 0.1% error rate on GCP + PostgreSQL/AlloyDB with layered backend architecture.",
      "Built an LLM agent for autonomous campaign management: generates data-driven creatives, pauses underperforming ads and reactivates winning campaigns using pgvector memory and 7 deterministic guardrails.",
      "Developed end-to-end sales tracking — ad → click → menu → order — via Meta Pixel + CAPI, connecting ad spend, campaigns, consumers and orders for ROAS, CAC and per-store revenue metrics.",
      "Set up observability stack with PostHog for feature flags and zero-deploy rollouts, Sentry for production monitoring and Metabase for data-driven analytics and decisions.",
    ],
    current: true,
  },
  {
    role: "Software Engineer",
    company: "LEVTY",
    period: "Aug 2023 — Jul 2024",
    location: "Remote",
    bullets: [
      "Developed features for an enterprise platform serving a large Brazilian educational organization, reaching 100,000+ interactions in 4 months.",
      "Modelled processes and integrations across all-in-one platforms (BPM, ECM, CRM), connecting business workflows to legacy systems for enterprise clients.",
    ],
    current: false,
  },
  {
    role: "Full Stack Intern",
    company: "dti digital",
    period: "Mar 2021 — Jan 2023",
    location: "Remote",
    bullets: [
      "Developed frontend and backend components for the redesign of an integrated management platform for Brazil's largest mining client.",
      "Worked with JavaScript, TypeScript, React, C#, .NET, Java and Spring Boot, including Jest/xUnit testing and CI/CD pipelines on Azure.",
    ],
    current: false,
  },
];

const skills = [
  { label: "Languages", items: "TypeScript · JavaScript · C# · SQL" },
  { label: "Frontend", items: "Vue.js · Nuxt · React · Next.js · Tailwind CSS" },
  { label: "Backend / Cloud", items: "Node.js · GCP · Cloud Functions · Cloud Tasks · Firebase · Docker · GitHub Actions" },
  { label: "Databases", items: "PostgreSQL · AlloyDB · MySQL · Firestore · Supabase · pgvector" },
  { label: "AI & Integrations", items: "OpenAI · LLMs · Meta Marketing API · Meta Pixel / CAPI · WhatsApp API · Starkbank API" },
  { label: "Observability & Analytics", items: "PostHog · Sentry · Metabase" },
  { label: "Tools", items: "Prisma · Zod · Git · CI/CD" },
  { label: "Languages (spoken)", items: "Portuguese (native) · English (full professional) · Spanish (intermediate) · Italian (elementary)" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { --text: #111; --muted: #555; --border: #ddd; --bg: #fff; --accent: #9c1f33; }
      html, body { min-height: 100%; }
      body {
        font-family: Charter, Georgia, serif;
        font-size: 10.5pt;
        color: var(--text);
        background: #e8e8e8;
        line-height: 1.5;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px 60px;
      }
      .cv-page { background: #fff; max-width: 780px; width: 100%; padding: 48px 56px; box-shadow: 0 4px 24px rgba(0,0,0,0.12); }
      .lang-btn {
        position: fixed; top: 20px; left: 20px;
        background: white; color: var(--text); border: 1px solid #ccc;
        border-radius: 8px; padding: 8px 16px; font-size: 13px;
        font-family: system-ui, sans-serif; cursor: pointer; font-weight: 600;
        z-index: 99; text-decoration: none; display: inline-block;
      }
      .lang-btn:hover { border-color: #999; }
      .print-btn {
        position: fixed; top: 20px; right: 20px;
        background: var(--accent); color: white; border: none;
        border-radius: 8px; padding: 8px 16px; font-size: 13px;
        font-family: system-ui, sans-serif; cursor: pointer; font-weight: 600; z-index: 99;
      }
      .print-btn:hover { opacity: 0.9; }
      .cv-header { text-align: center; margin-bottom: 20px; }
      .cv-name { font-size: 26pt; font-weight: 700; letter-spacing: -0.02em; }
      .cv-contacts { margin-top: 6px; font-size: 9pt; color: var(--muted); font-family: system-ui, sans-serif; display: flex; flex-wrap: wrap; justify-content: center; gap: 4px 12px; }
      .cv-contacts a { color: var(--text); text-decoration: none; }
      .cv-contacts a:hover { text-decoration: underline; }
      section { margin-top: 18px; }
      h2 { font-size: 11.5pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 1.5px solid var(--text); padding-bottom: 2px; margin-bottom: 10px; }
      .exp { margin-bottom: 14px; }
      .exp-header { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 2px; }
      .exp-title { font-weight: 700; font-size: 10.5pt; }
      .exp-company { font-weight: 400; }
      .exp-meta { font-size: 9pt; color: var(--muted); font-family: system-ui, sans-serif; text-align: right; }
      .exp ul { margin-top: 4px; padding-left: 14px; list-style: disc; }
      .exp li { margin-bottom: 2px; font-size: 9.5pt; }
      .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 24px; font-size: 9.5pt; }
      .skill-row strong { font-weight: 700; }
      .project { margin-bottom: 8px; font-size: 9.5pt; }
      .project-header { display: flex; justify-content: space-between; align-items: baseline; }
      .project a { font-weight: 700; color: var(--text); text-decoration: none; }
      .project a:hover { text-decoration: underline; }
      .project-year { font-size: 9pt; color: var(--muted); font-family: system-ui, sans-serif; }
      .project-desc { color: var(--muted); margin-top: 1px; }
      @media print {
        body { padding: 0; font-size: 9.5pt; background: #fff; }
        .cv-page { box-shadow: none; padding: 0; }
        .print-btn, .lang-btn { display: none !important; }
        @page { margin: 1.8cm 1.6cm; size: A4; }
        section { margin-top: 14px; }
        .exp { margin-bottom: 10px; }
      }
    </style>
  </head>
  <body>
    <a class="lang-btn" href="/curriculo">PT</a>
    <button class="print-btn" onclick="window.print()">⬇ Download PDF</button>

    <div class="cv-page">

    <header class="cv-header">
      <p class="cv-name">Leonardo Basso</p>
      <div class="cv-contacts">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <span>·</span>
        <a href="tel:+5535998794471">+55 35 99879 4471</a>
        <span>·</span>
        <a href={SITE.socials.linkedin}>linkedin.com/in/leojunioyuri</a>
        <span>·</span>
        <a href={SITE.socials.github}>github.com/leojunioyuri</a>
        <span>·</span>
        <a href={SITE.url}>leojunioyuri.github.io</a>
      </div>
      <p style="margin-top:6px;font-size:9pt;font-family:system-ui,sans-serif;color:#555;">
        São José dos Campos, Brazil · <strong style="color:#111;">Italian citizen (EU)</strong> — eligible to work in the EU without visa sponsorship
      </p>
    </header>

    <section>
      <h2>Summary</h2>
      <p style="font-size:9.5pt;">
        Product Engineer with experience building full-stack products, AI systems, data platforms and financial automations at scale.
        Lead engineer of MetaAds at Brendi — R$20M+ in tracked sales, R$500k+/month in managed ad budget and 10M+ requests/month in production.
      </p>
    </section>

    <section>
      <h2>Experience</h2>
      {experiences.map(exp => (
        <div class="exp">
          <div class="exp-header">
            <span class="exp-title">{exp.role} <span class="exp-company">· {exp.company}</span></span>
            <div class="exp-meta"><div>{exp.period}</div><div>{exp.location}</div></div>
          </div>
          <ul>{exp.bullets.map(b => <li>{b}</li>)}</ul>
        </div>
      ))}
    </section>

    <section>
      <h2>Education</h2>
      <div class="exp">
        <div class="exp-header">
          <span class="exp-title">B.Sc. Computer Science <span class="exp-company">· UFLA</span></span>
          <div class="exp-meta"><div>Aug 2018 — Dec 2023</div><div>Lavras, MG</div></div>
        </div>
        <ul>
          <li>President of CIMVEST (2021): built the first investment & financial education hub at UFLA, growing from 10 to 40 members. 1st Symposium with 300+ attendees.</li>
          <li>Tech Lead & Frontend Developer at Comp Júnior (2019–2021): junior software company at UFLA, technical leadership and project delivery for real clients.</li>
        </ul>
      </div>
    </section>

    <section>
      <h2>Skills</h2>
      <div class="skills-grid">
        {skills.map(s => <p class="skill-row"><strong>{s.label}:</strong> {s.items}</p>)}
      </div>
    </section>

    </div>
  </body>
</html>
