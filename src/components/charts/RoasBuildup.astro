---
// ROAS cumulativo — cohort fev/02 (206 lojas, semanas 0–19)
// Points mapped to viewBox 0 0 700 160
---

<div class="not-prose my-6 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-5">
  <p class="mb-4 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
    ROAS cumulativo — cohort fev/02 · semanas 0–19 (n=206 lojas)
  </p>
  <div style="overflow-x:auto;">
    <svg viewBox="0 0 700 170" style="min-width:480px;width:100%;height:auto;" aria-label="ROAS buildup curve">
      <defs>
        <linearGradient id="roas-fill" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.2"/>
          <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
        </linearGradient>
      </defs>

      <!-- Grid lines -->
      {[20,52,84,116,148].map((y, i) => (
        <>
          <line x1="44" y1={y} x2="690" y2={y} stroke="var(--border)" stroke-width="0.6"/>
          <text x="38" y={y+4} text-anchor="end" font-size="9" fill="var(--muted)" font-family="var(--font-mono)">
            {['13×','10×','7×','4×','1×'][i]}
          </text>
        </>
      ))}

      <!-- Area + Line -->
      <path
        d="M44,148 L79,136 L114,127 L149,123 L184,115 L219,106 L254,97 L289,89 L324,82 L359,77 L394,74 L429,69 L464,63 L499,60 L534,57 L569,55 L604,53 L639,50 L674,47 L690,47 L690,148 Z"
        fill="url(#roas-fill)"
      />
      <path
        d="M44,148 L79,136 L114,127 L149,123 L184,115 L219,106 L254,97 L289,89 L324,82 L359,77 L394,74 L429,69 L464,63 L499,60 L534,57 L569,55 L604,53 L639,50 L674,47 L690,47"
        fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
      />

      <!-- Key dots -->
      <circle cx="44"  cy="148" r="3" fill="var(--accent)"/>
      <circle cx="289" cy="89"  r="3" fill="var(--accent)"/>
      <circle cx="690" cy="47"  r="4" fill="var(--accent)"/>

      <!-- Annotations -->
      <text x="50"  y="143" font-size="9" fill="var(--accent)" font-family="var(--font-mono)" font-weight="600">2,9×</text>
      <text x="295" y="85"  font-size="9" fill="var(--accent)" font-family="var(--font-mono)" font-weight="600">10,1×</text>
      <text x="654" y="43"  font-size="9" fill="var(--accent)" font-family="var(--font-mono)" font-weight="700">12,6×</text>

      <!-- Phase labels -->
      <rect x="44" y="8" width="130" height="13" fill="var(--surface-2)" rx="2"/>
      <text x="109" y="18" text-anchor="middle" font-size="8" fill="var(--muted)" font-family="var(--font-mono)">COLD START · 2,9→6×</text>
      <rect x="254" y="8" width="130" height="13" fill="var(--accent-soft)" rx="2"/>
      <text x="319" y="18" text-anchor="middle" font-size="8" fill="var(--accent)" font-family="var(--font-mono)">COMPOUNDING · 10×+</text>

      <!-- Average line at 9.31x ≈ y=77 -->
      <line x1="44" y1="77" x2="690" y2="77" stroke="var(--muted)" stroke-width="0.6" stroke-dasharray="4,5" opacity="0.5"/>
      <text x="50" y="74" font-size="8" fill="var(--muted)" font-family="var(--font-mono)" opacity="0.7">média 9,31×</text>

      <!-- X axis -->
      {[0,5,10,15,19].map((w, i) => {
        const x = 44 + (i === 4 ? 646 : i * 161.5);
        return <text x={x} y="165" text-anchor="middle" font-size="9" fill="var(--muted)" font-family="var(--font-mono)">sem {w}</text>;
      })}
    </svg>
  </div>
</div>
