---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MetaAdsSystem from "@/components/diagrams/MetaAdsSystem.astro";
import CampaignLoop from "@/components/diagrams/CampaignLoop.astro";
import AndersonLoop from "@/components/diagrams/AndersonLoop.astro";
import type { Lang } from "@/consts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const pt = lang === "pt";

const path = pt ? "/brendi" : "/en/brendi";

const meta = {
  title: pt ? "Brendi — Case completo" : "Brendi — Full case study",
  description: pt
    ? "Como construí o MetaAds na Brendi: de 2 lojas a 2.000+ restaurantes com IA gerindo campanhas de forma autônoma."
    : "How I built MetaAds at Brendi: from 2 stores to 2,000+ restaurants with AI running campaigns autonomously.",
};

const metrics = pt
  ? [
      { value: "2.000+", label: "restaurantes atendidos (acum.)" },
      { value: "600+",   label: "lojas ativas hoje" },
      { value: "R$4M+",  label: "em mídia gerida (acum.)" },
      { value: "R$20M+", label: "em vendas rastreadas (acum.)" },
      { value: "R$500k+",label: "em verba / mês (run-rate)" },
      { value: "20",     label: "meses construindo" },
    ]
  : [
      { value: "2,000+", label: "restaurants served (cumul.)" },
      { value: "600+",   label: "active stores today" },
      { value: "R$4M+",  label: "in media managed (cumul.)" },
      { value: "R$20M+", label: "in tracked sales (cumul.)" },
      { value: "R$500k+",label: "in budget / month (run-rate)" },
      { value: "20",     label: "months building" },
    ];

const pillars = pt
  ? [
      {
        n: "01", icon: "🏪",
        title: "MetaAds Platform",
        desc: "Substitui uma agência de tráfego com custo 10x menor. Ativa toda semana, opera de forma autônoma e entrega ao dono o que realmente importa: pedidos, ROAS e custo por pedido.",
        items: [
          "Criativos por IA: banner, foto aprimorada (Gemini), vídeo curto (Kling, Veo, MimeClip)",
          "Copy em cascade de modelos — Claude, GPT-5, com fallback automático",
          "Dashboard com funil completo: alcance → cardápio → pedido",
          "Onboarding self-service em menos de 10 minutos",
          "Cobrança automática semanal alinhada ao ciclo do Meta — sem boleto, sem aprovação manual",
        ],
      },
      {
        n: "02", icon: "🤖",
        title: "Anderson — O agente autônomo",
        desc: "Anderson gerencia campanhas toda semana sem intervenção humana. Observa os dados, delibera com reasoning model, valida contra 7 guardrails de segurança e aplica na Meta API. Aprende com cada ciclo via memória vetorial.",
        items: [
          "Ciclo semanal: Observar → Deliberar → Validar → Aplicar → Reportar",
          "Guardrails que bloqueiam decisões perigosas (ex: ad <7 dias não é pausado)",
          "Memória de ROAS real entre ciclos — não começa do zero toda semana",
          "Resultado de cada ad alimenta a decisão da semana seguinte",
        ],
      },
      {
        n: "03", icon: "📊",
        title: "Data Layer",
        desc: "Toda decisão do sistema é derivada de dados. Monitoramos 600+ lojas em tempo real com dashboards no Metabase sobre AlloyDB. Análises ad-hoc rodam via scripts no Replit, compartilhados entre o time em segundos.",
        items: [
          "Metabase com 150+ cards: cobertura, cohort de ativação, ROAS por semana",
          "Scripts de análise profunda: ROAS drivers, cohort matrix, atribuição anti-viés por loja",
          "Replit como camada de análise rápida — de pergunta a CSV em minutos",
          "Relatório semanal automático no Slack: onboardings, churns, reativações, net, erros",
        ],
      },
    ]
  : [
      {
        n: "01", icon: "🏪",
        title: "MetaAds Platform",
        desc: "Replaces a paid-traffic agency at 10x lower cost. Activates every week, runs autonomously, and delivers what the owner actually needs: orders, ROAS and cost per order.",
        items: [
          "AI creatives: banner, enhanced photo (Gemini), short video (Kling, Veo, MimeClip)",
          "Copy via model cascade — Claude, GPT-5, with automatic fallback",
          "Dashboard with full funnel: reach → menu → order",
          "Self-service onboarding in under 10 minutes",
          "Automatic weekly billing aligned to Meta's cycle — no manual approval",
        ],
      },
      {
        n: "02", icon: "🤖",
        title: "Anderson — The autonomous agent",
        desc: "Anderson manages campaigns every week without human intervention. Observes data, deliberates with a reasoning model, validates against 7 safety guardrails, and applies via Meta API. Learns from each cycle via vector memory.",
        items: [
          "Weekly cycle: Observe → Deliberate → Validate → Apply → Report",
          "Guardrails block dangerous decisions (e.g. ads <7 days old are never paused)",
          "Real ROAS memory across cycles — doesn't start from scratch every week",
          "Each ad's outcome feeds next week's decision",
        ],
      },
      {
        n: "03", icon: "📊",
        title: "Data Layer",
        desc: "Every system decision is data-driven. We monitor 600+ stores in real time with Metabase dashboards on AlloyDB. Ad-hoc analyses run via Replit scripts, shared across the team in seconds.",
        items: [
          "Metabase with 150+ cards: coverage, activation cohort, weekly ROAS",
          "Deep analysis scripts: ROAS drivers, cohort matrix, anti-bias attribution per store",
          "Replit as rapid analysis layer — question to CSV in minutes",
          "Automated weekly Slack report: onboardings, churns, reactivations, net, errors",
        ],
      },
    ];

const highlight = pt
  ? {
      label: "Decisão que mais impactou",
      title: "ICP errado → churn de 50% para 4%",
      body: "Análise de cohorts mostrou que estávamos atraindo restaurantes fora do ICP ideal — pequenos demais, sem histórico de anúncio, com expectativa errada. Adicionamos uma trava no onboarding: apenas restaurantes com faturamento mínimo passavam. O churn despencou de 50% para 4% no mês seguinte. A base ficou menor, mas muito mais saudável.",
    }
  : {
      label: "Highest-impact decision",
      title: "Wrong ICP → churn from 50% to 4%",
      body: "Cohort analysis showed we were attracting restaurants outside the ideal ICP — too small, no advertising history, wrong expectations. We added a fee gate at onboarding: only restaurants above a minimum revenue threshold could proceed. Churn dropped from 50% to 4% the following month. The base got smaller, but far healthier.",
    };

const engItems = pt
  ? [
      "Migração Firestore → PostgreSQL/AlloyDB: 220+ migrations Prisma, leituras híbridas durante cutover, zero downtime",
      "Layered Architecture (Controller → Service → Repository) com Zod na entrada — cada camada tem responsabilidade única e testável",
      "PostHog: feature flags por storeId para rollouts sem deploy + event tracking de cohorts e conversões",
      "Sentry: monitoramento com gauge metrics, 10% trace sampling, context tags por módulo",
      "Padrão Trigger → Worker com Cloud Tasks: crons disparam batches de lojas, workers processam com backoff exponencial",
      "Anderson: memória pgvector + loop de atribuição — ROAS real alimenta decisão da semana seguinte",
      "Connection pooling context-aware: API (10 conexões) vs workers (3) — sem vazamento de pool em funções serverless",
      "Financial ledger próprio: cobrança semanal automatizada, prepaid via PIX e investimento na Meta API — R$500k+/mês em verba de clientes movimentados de forma autônoma, sem operador humano no loop",
    ]
  : [
      "Firestore → PostgreSQL/AlloyDB migration: 220+ Prisma migrations, hybrid reads during cutover, zero downtime",
      "Layered Architecture (Controller → Service → Repository) with Zod at input layer — each layer has a single, testable responsibility",
      "PostHog: per-store feature flags for no-deploy rollouts + event tracking for cohorts and conversions",
      "Sentry: monitoring with gauge metrics, 10% trace sampling, per-module context tags",
      "Trigger → Worker pattern with Cloud Tasks: crons fan-out 50-store batches, workers process with exponential backoff",
      "Anderson: pgvector memory + attribution loop — real ROAS feeds next week's decisions",
      "Context-aware connection pooling: API (10 conns) vs workers (3) — no pool leaks in serverless functions",
      "Own financial ledger: automated weekly billing, prepaid via PIX and Meta API investment — R$500k+/month in client budget moved autonomously, no human operator in the loop",
    ];
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} path={path}>
  <article class="mx-auto max-w-3xl px-5 py-20 sm:px-6">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-[var(--muted)]">
      <a href={pt ? "/" : "/en/"} class="hover:text-[var(--fg)]">
        {pt ? "Início" : "Home"}
      </a>
      <span>·</span>
      <span class="text-[var(--fg)]">Brendi</span>
    </nav>

    <!-- Header -->
    <header>
      <p class="text-sm font-medium text-[var(--accent)]">
        Brendi · {pt ? "2024 — hoje" : "2024 — present"}
      </p>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
        {pt ? "MetaAds: um sistema que move números" : "MetaAds: a system that moves numbers"}
      </h1>
      <p class="mt-4 max-w-2xl text-xl text-[var(--muted)]">
        {pt
          ? "De 2 lojas ativas para 2.000+ restaurantes, R$4M+ em mídia gerida e R$20M+ em vendas rastreadas — com IA gerindo campanhas de forma autônoma."
          : "From 2 active stores to 2,000+ restaurants, R$4M+ in media managed and R$20M+ in tracked sales — with AI running campaigns autonomously."}
      </p>
    </header>

    <!-- Metrics grid -->
    <dl class="mt-12 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--border)] sm:grid-cols-3">
      {metrics.map((m) => (
        <div class="bg-[var(--bg)] px-5 py-5">
          <dt class="text-3xl font-bold tracking-tight">{m.value}</dt>
          <dd class="mt-1 text-sm text-[var(--muted)]">{m.label}</dd>
        </div>
      ))}
    </dl>

    <!-- Context -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "O contexto" : "The context"}
      </h2>
      <div class="prose mt-4">
        {pt ? (
          <>
            <p>A Brendi resolve um problema real: restaurantes independentes precisam de clientes, mas diferente do iFood — onde o marketplace traz o cliente — no canal próprio isso é responsabilidade deles. Contratar agência custa caro e não escala. Fazer sozinho é inviável.</p>
            <p>O MetaAds é a resposta: um sistema que faz o trabalho de uma agência de tráfego pago de forma autônoma, com o objetivo de entregar 10x mais resultado e ser 10x mais barato. Configuração, investimento automático, gestão de campanhas, orçamento, priorização — e um agente de IA que cria, pausa e reativa anúncios baseado em dados, com foco em trazer mais vendas.</p>
            <p>Foram mais de 20 meses construindo e aprendendo — com dados e, principalmente, com os clientes. Hoje temos um modelo que gerou R$20M+ em vendas rastreadas e entrega retorno médio de 10x sobre o investimento. E estamos crescendo.</p>
          </>
        ) : (
          <>
            <p>Brendi solves a real problem: independent restaurants need customers, but unlike iFood — where the marketplace brings the customer — on their own channel, that's their responsibility. Hiring an agency is expensive and doesn't scale. Doing it alone is not viable.</p>
            <p>MetaAds is the answer: a system that does the work of a paid-traffic agency autonomously, with the goal of delivering 10x more results and costing 10x less than an agency. Setup, automatic investment, ad management, budget, prioritization — and an AI agent that creates, pauses and reactivates ads based on data, focused on driving more sales.</p>
            <p>More than 20 months building and learning — from data and, above all, from customers. Today we have a model that generated R$20M+ in tracked sales and delivers an average 10x return on investment. And we're growing.</p>
          </>
        )}
      </div>
    </section>

    <!-- MetaAds System diagram -->
    <div class="mt-10">
      <MetaAdsSystem lang={lang} />
    </div>

    <!-- 3 Pillars -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "Os três pilares" : "The three pillars"}
      </h2>
      <div class="mt-6 flex flex-col gap-6">
        {pillars.map((p) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 sm:p-7">
            <div class="flex items-center gap-3">
              <span class="text-2xl" aria-hidden="true">{(p as any).icon}</span>
              <div class="flex items-baseline gap-2">
                <span class="font-mono text-sm text-[var(--accent)]">{p.n}</span>
                <h3 class="text-xl font-bold tracking-tight">{p.title}</h3>
              </div>
            </div>
            <p class="mt-3 text-[var(--muted)]">{p.desc}</p>
            <ul class="mt-4 space-y-2">
              {p.items.map((item) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Product screenshots gallery -->
    <div class="mt-10">
      <p class="mb-4 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
        {pt ? "O produto em ação" : "The product in action"}
      </p>

      {/* All screenshots — clickable lightbox */}
      {[
        {
          src: "/metaads-dashboard.png",
          captionPt: "Resultados · R$441 investidos → R$14k em vendas · 231 pedidos · 388 novos clientes · 31.7× retorno",
          captionEn: "Results · R$441 invested → R$14k in sales · 231 orders · 388 new customers · 31.7× return",
          wide: true,
        },
        {
          src: "/metaads-anderson.png",
          captionPt: "Gestor Anderson · relatório semanal + chat IA — o dono tira dúvidas, entende o ROI e aprende sobre o tráfego da sua loja",
          captionEn: "Anderson Manager · weekly report + AI chat — owner asks questions, understands ROI and learns about their store's traffic",
          wide: true,
        },
        {
          src: "/metaads-curso.png",
          captionPt: "Ajuda · curso gravado integrado ao produto — o dono aprende sobre tráfego pago diretamente na plataforma",
          captionEn: "Help · recorded course integrated into the product — owner learns about paid traffic directly on the platform",
          wide: true,
        },
      ].map(s => (
        <figure
          data-lb-src={s.src}
          data-lb-caption={pt ? s.captionPt : s.captionEn}
          class="lb-trigger mt-3 cursor-zoom-in overflow-hidden rounded-xl border border-[var(--border)] transition-opacity hover:opacity-90"
        >
          <img src={s.src} alt={pt ? s.captionPt : s.captionEn} loading="lazy" class="w-full" />
          <figcaption class="border-t border-[var(--border)] bg-[var(--surface)] px-4 py-2.5 text-xs text-[var(--muted)]">
            {pt ? s.captionPt : s.captionEn}
          </figcaption>
        </figure>
      ))}

      {/* Grid de 3 */}
      <div class="mt-3 grid gap-3 sm:grid-cols-3">
        {[
          { src: "/metaads-ads.png",
            captionPt: "Aba de anúncios — criativos reais com resultados por anúncio",
            captionEn: "Ads tab — real creatives with per-ad results" },
          { src: "/metaads-create-1.png",
            captionPt: "Criação de anúncio — mídia pronta, preview ao vivo",
            captionEn: "Ad creation — media ready, live preview" },
          { src: "/metaads-create-2.png",
            captionPt: "Revisão antes de publicar — link de cardápio + preview final",
            captionEn: "Review before publishing — menu link + final preview" },
        ].map(s => (
          <figure
            data-lb-src={s.src}
            data-lb-caption={pt ? s.captionPt : s.captionEn}
            class="lb-trigger cursor-zoom-in overflow-hidden rounded-xl border border-[var(--border)] transition-opacity hover:opacity-90"
          >
            <img src={s.src} alt={pt ? s.captionPt : s.captionEn} loading="lazy" class="w-full" />
            <figcaption class="border-t border-[var(--border)] bg-[var(--surface)] px-3 py-2 text-xs text-[var(--muted)]">
              {pt ? s.captionPt : s.captionEn}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>

    <!-- Lightbox dialog -->
    <dialog
      id="lb-dialog"
      class="m-auto w-full max-w-4xl rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-0 shadow-2xl backdrop:bg-black/70"
    >
      <div class="relative">
        <button
          id="lb-close"
          aria-label={pt ? "Fechar" : "Close"}
          class="absolute right-3 top-3 z-10 grid h-8 w-8 place-items-center rounded-full bg-black/50 text-white hover:bg-black/70"
        >✕</button>
        <img id="lb-img" src="" alt="" class="w-full rounded-t-2xl" />
        <p id="lb-caption" class="px-5 py-3 text-sm text-[var(--muted)]"></p>
      </div>
    </dialog>

    <!-- Anderson decision loop diagram -->
    <div class="mt-8">
      <AndersonLoop lang={lang} />
    </div>

    <!-- Campaign Loop diagram -->
    <div class="mt-4">
      <CampaignLoop lang={lang} />
    </div>

    <!-- MetaAds demo GIF -->
    <div class="mt-8">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
        {pt ? "O produto em ação" : "The product in action"}
      </p>
      <img
        src="/metaads-demo.gif"
        alt={pt ? "MetaAds — criando um anúncio" : "MetaAds — creating an ad"}
        class="w-full rounded-xl border border-[var(--border)]"
        loading="lazy"
      />
    </div>

    <!-- Highlight: key decision -->
    <section class="mt-16 rounded-2xl border border-[var(--accent)] bg-[var(--accent-soft)] p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent)]">
        {highlight.label}
      </p>
      <h2 class="mt-2 text-xl font-bold tracking-tight">{highlight.title}</h2>
      <p class="mt-3 text-[var(--fg)]">{highlight.body}</p>
    </section>

    <!-- Engineering highlights -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "Engineering highlights" : "Engineering highlights"}
      </h2>
      <ul class="mt-5 grid gap-2 sm:grid-cols-2">
        {engItems.map((item) => (
          <li class="flex items-start gap-2.5 rounded-xl border border-[var(--border)] bg-[var(--surface)] px-4 py-3 text-sm">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Back -->
    <div class="mt-16 flex gap-4">
      <a href={pt ? "/" : "/en/"} class="text-sm font-semibold text-[var(--accent)] hover:underline">
        ← {pt ? "Voltar" : "Back"}
      </a>
      <a href={pt ? "/writing" : "/en/writing"} class="text-sm font-semibold text-[var(--muted)] hover:text-[var(--fg)]">
        {pt ? "Ler os bastidores →" : "Read behind the scenes →"}
      </a>
    </div>

  </article>
</BaseLayout>

<style is:global>
  #lb-dialog {
    opacity: 0;
    transform: scale(0.94);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }
  #lb-dialog[open] {
    opacity: 1;
    transform: scale(1);
  }
  #lb-dialog::backdrop {
    transition: background-color 0.22s ease;
  }
</style>

<script>
  const dlg    = document.getElementById('lb-dialog') as HTMLDialogElement | null;
  const lbImg  = document.getElementById('lb-img') as HTMLImageElement | null;
  const lbCap  = document.getElementById('lb-caption');
  const lbClose= document.getElementById('lb-close');

  document.querySelectorAll<HTMLElement>('.lb-trigger').forEach(fig => {
    fig.addEventListener('click', () => {
      if (!dlg || !lbImg || !lbCap) return;
      lbImg.src = fig.dataset.lbSrc ?? '';
      lbImg.alt = fig.dataset.lbCaption ?? '';
      lbCap.textContent = fig.dataset.lbCaption ?? '';
      dlg.showModal();
    });
  });

  lbClose?.addEventListener('click', () => dlg?.close());
  dlg?.addEventListener('click', e => { if (e.target === dlg) dlg.close(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') dlg?.close(); });
</script>
