---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Cases from "@/components/Cases.astro";
import Highlight from "@/components/Highlight.astro";
import About from "@/components/About.astro";
import Stack from "@/components/Stack.astro";
import Interests from "@/components/Interests.astro";
import WritingPreview from "@/components/WritingPreview.astro";
import Contact from "@/components/Contact.astro";
import { useTranslations } from "@/i18n/utils";
import { getPosts, slugOf } from "@/content-utils";
import type { Lang } from "@/consts";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const featuredSlug = "metaads-v3-turnaround";
const posts = await getPosts(lang);
const featuredAvailable = posts.some((p) => slugOf(p.id) === featuredSlug);

const path = lang === "pt" ? "/" : "/en/";

// First-visit language detection. Honors a stored choice, otherwise the browser
// language. Only the root pages redirect, and never loop.
const detectScript =
  lang === "pt"
    ? `(function(){try{var s=localStorage.getItem('lang');if(s==='en'){location.replace('/en/');}else if(!s){var n=(navigator.language||'').toLowerCase();if(n&&!n.startsWith('pt')){localStorage.setItem('lang','en');location.replace('/en/');}else{localStorage.setItem('lang','pt');}}}catch(e){}})();`
    : `(function(){try{if(localStorage.getItem('lang')==='pt'){location.replace('/');}}catch(e){}})();`;
---

<BaseLayout
  lang={lang}
  title="Leonardo Basso — Product Engineer"
  description={lang === "pt"
    ? "Leonardo Basso é Product Engineer construindo automação com IA para restaurantes. Construiu o MetaAds na Brendi — 2.000+ restaurantes, R$4M+ em mídia gerida e R$20M+ em vendas para os restaurantes."
    : "Leonardo Basso is a Product Engineer building AI automation for restaurant growth. He built core parts of MetaAds at Brendi, scaling to 2,000+ restaurants, R$4M+ in media managed and R$20M+ in sales."}
  path={path}
>
  <script is:inline set:html={detectScript} />

  <Hero lang={lang} />
  <Cases lang={lang} />
  <Highlight
    lang={lang}
    postSlug={featuredAvailable ? featuredSlug : undefined}
  />
  <About lang={lang} />
  <Stack lang={lang} />
  <Interests lang={lang} />
  <WritingPreview lang={lang} />
  <Contact lang={lang} />
</BaseLayout>
