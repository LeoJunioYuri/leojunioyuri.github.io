---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Architecture from "@/components/diagrams/Architecture.astro";
import CampaignLoop from "@/components/diagrams/CampaignLoop.astro";
import AndersonLoop from "@/components/diagrams/AndersonLoop.astro";
import type { Lang } from "@/consts";

interface Props { lang: Lang; }
const { lang } = Astro.props;
const pt = lang === "pt";

const path = pt ? "/brendi" : "/en/brendi";

const meta = {
  title: pt ? "Brendi — Case completo" : "Brendi — Full case study",
  description: pt
    ? "Como construí o MetaAds na Brendi: de 2 lojas a 2.000+ restaurantes com IA gerindo campanhas de forma autônoma."
    : "How I built MetaAds at Brendi: from 2 stores to 2,000+ restaurants with AI running campaigns autonomously.",
};

const metrics = pt
  ? [
      { value: "2.000+", label: "restaurantes ativos" },
      { value: "R$4M+", label: "em mídia gerida" },
      { value: "R$20M+", label: "em vendas" },
      { value: "10M+", label: "requests / mês" },
      { value: "20", label: "meses construindo" },
      { value: "~5×", label: "de crescimento no faturamento" },
    ]
  : [
      { value: "2,000+", label: "active restaurants" },
      { value: "R$4M+", label: "in media managed" },
      { value: "R$20M+", label: "tracked restaurant sales" },
      { value: "10M+", label: "requests / month" },
      { value: "20", label: "months building" },
      { value: "~5×", label: "revenue growth" },
    ];

const pillars = pt
  ? [
      {
        n: "01", icon: "🏪",
        title: "MetaAds Platform",
        desc: "O sistema end-to-end que substitui uma agência de tráfego — com custo 10x menor. Ativa na segunda-feira, investe automaticamente, gera criativos com IA e entrega ao dono um painel com o que realmente importa: pedidos, ROAS e custo por pedido.",
        items: [
          "4 níveis de agressividade: conservador → moderado → recomendado → agressivo",
          "Estúdio Criativo com IA: banner, foto e vídeo (Veo 3.1)",
          "Funil completo: alcance → cardápio → add to cart → pedido",
          "Onboarding self-service + cobrança automática semanal",
        ],
      },
      {
        n: "02", icon: "🤖",
        title: "Anderson — O agente autônomo",
        desc: "Anderson é o agente de IA que gerencia campanhas toda semana. Ciclo de 5 fases: Observar → Deliberar (GPT-5) → Validar → Aplicar → Reportar. Protegido por 7 guardrails determinísticos. Aprende com memória em pgvector entre ciclos.",
        items: [
          "7 guardrails vetam decisões inseguras — ad novo (<7 dias) nunca é tocado",
          "Memória pgvector: aprende com o ROAS real de ciclos anteriores",
          "Loop de atribuição: resultado de cada ad alimenta a decisão seguinte",
          "Criação autônoma: cria, pausa e reativa anúncios baseado em dados",
        ],
      },
      {
        n: "03", icon: "📊",
        title: "Data & Attribution Layer",
        desc: "Fecha o loop entre investimento e venda. Meta Pixel rastreia clique → abertura de cardápio → add to cart → pedido. Baseline anti-viés: ROAS calculado excluindo ads do Anderson para não contaminar a análise.",
        items: [
          "R$20M+ em vendas rastreadas · retorno médio 10x",
          "Rastreamento: clique → cardápio → add to cart → pedido",
          "Baseline anti-viés: exclui ads do Anderson do cálculo de ROAS",
          "Cohort analytics: retenção, GMV e disable rate por coorte",
        ],
      },
    ]
  : [
      {
        n: "01", icon: "🏪",
        title: "MetaAds Platform",
        desc: "The end-to-end system that replaces a paid-traffic agency — at 10x lower cost. Activates on Monday, invests automatically, generates AI creatives, and delivers a dashboard focused on what matters: orders, ROAS, and cost per order.",
        items: [
          "4 aggressiveness levels: conservative → moderate → recommended → aggressive",
          "Creative Studio with AI: banner, photo and video (Veo 3.1)",
          "Full funnel: reach → menu → add to cart → order",
          "Self-service onboarding + automatic weekly billing",
        ],
      },
      {
        n: "02", icon: "🤖",
        title: "Anderson — The autonomous agent",
        desc: "Anderson is the AI agent that manages campaigns every week. 5-phase cycle: Observe → Deliberate (GPT-5) → Validate → Apply → Report. Protected by 7 deterministic guardrails. Learns from pgvector memory across cycles.",
        items: [
          "7 guardrails veto unsafe decisions — new ads (<7 days) are never touched",
          "pgvector memory: learns from real ROAS of previous cycles",
          "Attribution loop: each ad's outcome feeds next week's decision",
          "Autonomous creation: creates, pauses and reactivates ads based on data",
        ],
      },
      {
        n: "03", icon: "📊",
        title: "Data & Attribution Layer",
        desc: "Closes the loop between investment and sale. Meta Pixel tracks click → menu open → add to cart → order. Anti-bias baseline: ROAS calculated excluding Anderson's ads to avoid contaminating the analysis.",
        items: [
          "R$20M+ in tracked sales · average 10x return",
          "Tracking: click → menu → add to cart → order",
          "Anti-bias baseline: excludes Anderson's ads from ROAS calculation",
          "Cohort analytics: retention, GMV and disable rate per cohort",
        ],
      },
    ];

const highlight = pt
  ? {
      label: "Decisão que mais impactou",
      title: "ICP errado → churn de 50% para 4%",
      body: "Análise de cohorts mostrou que estávamos atraindo restaurantes fora do ICP ideal — pequenos demais, sem histórico de anúncio, com expectativa errada. Adicionamos uma trava no onboarding: apenas restaurantes com faturamento mínimo passavam. O churn despencou de 50% para 4% no mês seguinte. A base ficou menor, mas muito mais saudável.",
    }
  : {
      label: "Highest-impact decision",
      title: "Wrong ICP → churn from 50% to 4%",
      body: "Cohort analysis showed we were attracting restaurants outside the ideal ICP — too small, no advertising history, wrong expectations. We added a fee gate at onboarding: only restaurants above a minimum revenue threshold could proceed. Churn dropped from 50% to 4% the following month. The base got smaller, but far healthier.",
    };

const engItems = pt
  ? [
      "Migração Firestore → PostgreSQL/AlloyDB: 220+ migrations Prisma, leituras híbridas durante cutover, zero downtime",
      "Layered Architecture (Controller → Service → Repository) com Zod na entrada — cada camada tem responsabilidade única e testável",
      "PostHog: feature flags por storeId para rollouts sem deploy + event tracking de cohorts e conversões",
      "Sentry: monitoramento com gauge metrics, 10% trace sampling, context tags por módulo",
      "Padrão Trigger → Worker com Cloud Tasks: crons disparam batches de lojas, workers processam com backoff exponencial",
      "Anderson: memória pgvector + loop de atribuição — ROAS real alimenta decisão da semana seguinte",
      "Connection pooling context-aware: API (10 conexões) vs workers (3) — sem vazamento de pool em funções serverless",
      "Personalização manual: opção para geração de vídeo com Veo 3.1 + banners GPT-Image com aprovação do dono",
    ]
  : [
      "Firestore → PostgreSQL/AlloyDB migration: 220+ Prisma migrations, hybrid reads during cutover, zero downtime",
      "Layered Architecture (Controller → Service → Repository) with Zod at input layer — each layer has a single, testable responsibility",
      "PostHog: per-store feature flags for no-deploy rollouts + event tracking for cohorts and conversions",
      "Sentry: monitoring with gauge metrics, 10% trace sampling, per-module context tags",
      "Trigger → Worker pattern with Cloud Tasks: crons fan-out 50-store batches, workers process with exponential backoff",
      "Anderson: pgvector memory + attribution loop — real ROAS feeds next week's decisions",
      "Context-aware connection pooling: API (10 conns) vs workers (3) — no pool leaks in serverless functions",
      "Creative Studio: video generation with Veo 3.1 + GPT-Image banners with owner approval flow",
    ];
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} path={path}>
  <article class="mx-auto max-w-3xl px-5 py-20 sm:px-6">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-[var(--muted)]">
      <a href={pt ? "/" : "/en/"} class="hover:text-[var(--fg)]">
        {pt ? "Início" : "Home"}
      </a>
      <span>·</span>
      <span class="text-[var(--fg)]">Brendi</span>
    </nav>

    <!-- Header -->
    <header>
      <p class="text-sm font-medium text-[var(--accent)]">
        Brendi · {pt ? "2024 — hoje" : "2024 — present"}
      </p>
      <h1 class="mt-2 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl">
        {pt ? "MetaAds: um sistema que move números" : "MetaAds: a system that moves numbers"}
      </h1>
      <p class="mt-4 max-w-2xl text-xl text-[var(--muted)]">
        {pt
          ? "De 2 lojas ativas para 2.000+ restaurantes, R$4M+ em mídia gerida e R$20M+ em vendas rastreadas — com IA gerindo campanhas de forma autônoma."
          : "From 2 active stores to 2,000+ restaurants, R$4M+ in media managed and R$20M+ in tracked sales — with AI running campaigns autonomously."}
      </p>
    </header>

    <!-- Metrics grid -->
    <dl class="mt-12 grid grid-cols-2 gap-px overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--border)] sm:grid-cols-3">
      {metrics.map((m) => (
        <div class="bg-[var(--bg)] px-5 py-5">
          <dt class="text-3xl font-bold tracking-tight">{m.value}</dt>
          <dd class="mt-1 text-sm text-[var(--muted)]">{m.label}</dd>
        </div>
      ))}
    </dl>

    <!-- Context -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "O contexto" : "The context"}
      </h2>
      <div class="prose mt-4">
        {pt ? (
          <>
            <p>A Brendi resolve um problema real: restaurantes independentes precisam de clientes, mas diferente do iFood — onde o marketplace traz o cliente — no canal próprio isso é responsabilidade deles. Contratar agência custa caro e não escala. Fazer sozinho é inviável.</p>
            <p>O MetaAds é a resposta: um sistema que faz o trabalho de uma agência de tráfego pago de forma autônoma, com o objetivo de entregar 10x mais resultado e ser 10x mais barato. Configuração, investimento automático, gestão de campanhas, orçamento, priorização — e um agente de IA que cria, pausa e reativa anúncios baseado em dados, com foco em trazer mais vendas.</p>
            <p>Foram mais de 20 meses construindo e aprendendo — com dados e, principalmente, com os clientes. Hoje temos um modelo que gerou R$20M+ em vendas rastreadas e entrega retorno médio de 10x sobre o investimento. E estamos crescendo.</p>
          </>
        ) : (
          <>
            <p>Brendi solves a real problem: independent restaurants need customers, but unlike iFood — where the marketplace brings the customer — on their own channel, that's their responsibility. Hiring an agency is expensive and doesn't scale. Doing it alone is not viable.</p>
            <p>MetaAds is the answer: a system that does the work of a paid-traffic agency autonomously, with the goal of delivering 10x more results and costing 10x less than an agency. Setup, automatic investment, ad management, budget, prioritization — and an AI agent that creates, pauses and reactivates ads based on data, focused on driving more sales.</p>
            <p>More than 20 months building and learning — from data and, above all, from customers. Today we have a model that generated R$20M+ in tracked sales and delivers an average 10x return on investment. And we're growing.</p>
          </>
        )}
      </div>
    </section>

    <!-- Architecture diagram -->
    <div class="mt-10">
      <Architecture lang={lang} />
    </div>

    <!-- 3 Pillars -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "Os três pilares" : "The three pillars"}
      </h2>
      <div class="mt-6 flex flex-col gap-6">
        {pillars.map((p) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 sm:p-7">
            <div class="flex items-center gap-3">
              <span class="text-2xl" aria-hidden="true">{(p as any).icon}</span>
              <div class="flex items-baseline gap-2">
                <span class="font-mono text-sm text-[var(--accent)]">{p.n}</span>
                <h3 class="text-xl font-bold tracking-tight">{p.title}</h3>
              </div>
            </div>
            <p class="mt-3 text-[var(--muted)]">{p.desc}</p>
            <ul class="mt-4 space-y-2">
              {p.items.map((item) => (
                <li class="flex items-start gap-2 text-sm">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-[var(--accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Anderson decision loop diagram -->
    <div class="mt-8">
      <AndersonLoop lang={lang} />
    </div>

    <!-- Campaign Loop diagram -->
    <div class="mt-4">
      <CampaignLoop lang={lang} />
    </div>

    <!-- MetaAds demo GIF -->
    <div class="mt-8">
      <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
        {pt ? "O produto em ação" : "The product in action"}
      </p>
      <img
        src="/metaads-demo.gif"
        alt={pt ? "MetaAds — criando um anúncio" : "MetaAds — creating an ad"}
        class="w-full rounded-xl border border-[var(--border)]"
        loading="lazy"
      />
    </div>

    <!-- Highlight: key decision -->
    <section class="mt-16 rounded-2xl border border-[var(--accent)] bg-[var(--accent-soft)] p-6 sm:p-8">
      <p class="text-xs font-semibold uppercase tracking-wide text-[var(--accent)]">
        {highlight.label}
      </p>
      <h2 class="mt-2 text-xl font-bold tracking-tight">{highlight.title}</h2>
      <p class="mt-3 text-[var(--fg)]">{highlight.body}</p>
    </section>

    <!-- Engineering highlights -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">
        {pt ? "Engineering highlights" : "Engineering highlights"}
      </h2>
      <ul class="mt-5 grid gap-2 sm:grid-cols-2">
        {engItems.map((item) => (
          <li class="flex items-start gap-2.5 rounded-xl border border-[var(--border)] bg-[var(--surface)] px-4 py-3 text-sm">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]" />
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Back -->
    <div class="mt-16 flex gap-4">
      <a href={pt ? "/" : "/en/"} class="text-sm font-semibold text-[var(--accent)] hover:underline">
        ← {pt ? "Voltar" : "Back"}
      </a>
      <a href={pt ? "/writing" : "/en/writing"} class="text-sm font-semibold text-[var(--muted)] hover:text-[var(--fg)]">
        {pt ? "Ler os bastidores →" : "Read behind the scenes →"}
      </a>
    </div>

  </article>
</BaseLayout>
