---
import { SITE, type Lang } from "@/consts";
import { useTranslations, localizedPath } from "@/i18n/utils";
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const lifePath = localizedPath(lang, "life");
---

<section id="about" class="scroll-mt-20 border-t border-[var(--border)]">
  <div class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <h2 data-reveal-scroll class="text-2xl font-bold tracking-tight sm:text-3xl">
      {t("about.title")}
    </h2>

    <div data-reveal-scroll class="mt-8 flex flex-col gap-8 sm:flex-row sm:items-stretch sm:gap-10">
      <!-- Foto — estica para igualar a altura do texto -->
      <div class="h-56 overflow-hidden rounded-2xl shadow-lg ring-2 ring-[var(--border)] sm:h-full sm:w-52 sm:shrink-0">
        <img
          src={SITE.photo}
          alt="Leonardo Basso"
          loading="lazy"
          class="h-full w-full object-cover object-top transition-transform duration-500 ease-out hover:scale-[1.06]"
        />
      </div>

      <!-- Texto -->
      <div class="space-y-4 text-lg leading-relaxed text-[var(--fg)]">
        <p>{t("about.body")}</p>
        <p class="text-[var(--muted)]">{t("about.body2")}</p>
        <a
          href={lifePath}
          class="inline-flex text-sm font-semibold text-[var(--accent)] hover:underline"
        >
          {lang === "pt" ? "Vida fora do código →" : "Life outside the code →"}
        </a>
      </div>
    </div>
  </div>
</section>
