---
import { SITE } from "@/consts";

const title = "Currículo — Leonardo Basso";
const description = "Product Engineer · Brendi · leojunioyuri.github.io";

const experiences = [
  {
    role: "Product Engineer · Founding Team",
    company: "Brendi",
    period: "Out 2024 — presente",
    location: "São José dos Campos, SP",
    bullets: [
      "Liderei o desenvolvimento do MetaAds, plataforma autônoma de tráfego pago para restaurantes, escalando de 0 até produção na base de 2.000+ restaurantes da Brendi — R$20M+ em vendas rastreadas e ROAS médio de 10×.",
      "Atuei como principal engenheiro responsável pela arquitetura, implementação e evolução do produto, eliminando a operação manual recorrente do fluxo financeiro com camada própria de orçamento, investimento e receita — R$500k+/mês em verba gerida.",
      "Projetei e implementei APIs serverless que chegam a 10M+ requests/mês, p95 < 200ms e 0,1% error rate, em GCP + PostgreSQL/AlloyDB com Layered Architecture.",
      "Implementei agente LLM para gestão autônoma de campanhas, gerando criativos com base em dados, pausando anúncios de baixo desempenho e reativando campanhas vencedoras com memória pgvector e 7 guardrails determinísticos.",
      "Desenvolvi sistema de rastreamento de vendas no funil anúncio → clique → cardápio → pedido via Meta Pixel + CAPI, conectando investimento, anúncios, consumidores e pedidos para métricas de ROAS, CAC e receita por loja.",
      "Configurei stack de observabilidade com PostHog para feature flags e rollouts sem deploy, Sentry para monitoramento em produção e Metabase para analytics e decisões movidas a dados.",
    ],
    current: true,
  },
  {
    role: "Engenheiro de Software",
    company: "LEVTY",
    period: "Ago 2023 — Jul 2024",
    location: "Remoto",
    bullets: [
      "Desenvolvi funcionalidades para plataforma enterprise de organização educacional no Brasil, atingindo 100.000+ interações em 4 meses.",
      "Modelei processos e integrações em plataformas all-in-one (BPM, ECM, CRM), conectando fluxos de negócio a sistemas legados para clientes enterprise.",
    ],
    current: false,
  },
  {
    role: "Estagiário Full Stack",
    company: "dti digital",
    period: "Mar 2021 — Jan 2023",
    location: "Belo Horizonte, MG",
    bullets: [
      "Desenvolvi componentes frontend e backend na reformulação de plataforma integrada de gestão para o maior cliente de mineração do Brasil.",
      "Atuei com JavaScript, TypeScript, React, C#, .NET, Java e Spring Boot, incluindo testes com Jest/xUnit e pipelines CI/CD no Azure.",
    ],
    current: false,
  },
  {
    role: "Tech Lead & Desenvolvedor Frontend",
    company: "Comp Júnior · UFLA",
    period: "Jun 2019 — Jan 2021",
    location: "Lavras, MG",
    bullets: [
      "Tech Lead em empresa júnior — liderança técnica, distribuição de conhecimento e entrega de projetos reais para clientes.",
    ],
    current: false,
  },
];

const skills = [
  { label: "Linguagens", items: "TypeScript · JavaScript · C# · SQL" },
  { label: "Frontend", items: "Vue.js · Nuxt · React · Next.js · Tailwind CSS" },
  { label: "Backend / Cloud", items: "Node.js · GCP · Cloud Functions · Cloud Tasks · Firebase · Docker · GitHub Actions" },
  { label: "Banco de Dados", items: "PostgreSQL · AlloyDB · MySQL · Firestore · Supabase · pgvector" },
  { label: "IA & Integrações", items: "OpenAI · LLMs · Meta Marketing API · Meta Pixel / CAPI · WhatsApp API · Starkbank API" },
  { label: "Observabilidade & Analytics", items: "PostHog · Sentry · Metabase" },
  { label: "Ferramentas", items: "Prisma · Zod · Git · CI/CD" },
  { label: "Idiomas", items: "Português (nativo) · Inglês (avançado) · Espanhol (intermediário) · Italiano (básico)" },
];

const projects = [
  { name: "Site Pessoal & Portfólio", url: "https://leojunioyuri.github.io", year: "2026", desc: "Portfólio bilíngue em Astro + Tailwind CSS com integrações ao vivo: Spotify, Steam, Xbox, Battle.net, Letterboxd. Dark/light mode, case study completo do MetaAds e currículo web." },
  { name: "Pensão Mansão Azul", url: "https://www.pensaomansaoazul.com.br/", year: "2023", desc: "Site em React, TypeScript, Next.js e .NET para pensão estudantil. ~3.000 pessoas na primeira semana." },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --text: #111;
        --muted: #555;
        --border: #ddd;
        --bg: #fff;
        --accent: #9c1f33;
      }

      html, body {
        min-height: 100%;
      }

      body {
        font-family: Charter, Georgia, serif;
        font-size: 10.5pt;
        color: var(--text);
        background: #e8e8e8;
        line-height: 1.5;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px 60px;
      }

      .cv-page {
        background: #fff;
        max-width: 780px;
        width: 100%;
        padding: 48px 56px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.12);
      }

      /* ── BUTTONS ── */
      .lang-btn {
        position: fixed;
        top: 20px;
        left: 20px;
        background: white;
        color: var(--text);
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 8px 16px;
        font-size: 13px;
        font-family: system-ui, sans-serif;
        cursor: pointer;
        font-weight: 600;
        z-index: 99;
        text-decoration: none;
        display: inline-block;
      }
      .lang-btn:hover { border-color: #999; }

      .print-btn {
        position: fixed;
        top: 20px;
        right: 20px;
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-size: 13px;
        font-family: system-ui, sans-serif;
        cursor: pointer;
        font-weight: 600;
        z-index: 99;
      }
      .print-btn:hover { opacity: 0.9; }

      /* ── HEADER ── */
      .cv-header { text-align: center; margin-bottom: 20px; }
      .cv-name { font-size: 26pt; font-weight: 700; letter-spacing: -0.02em; }
      .cv-contacts {
        margin-top: 6px;
        font-size: 9pt;
        color: var(--muted);
        font-family: system-ui, sans-serif;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 4px 12px;
      }
      .cv-contacts a { color: var(--text); text-decoration: none; }
      .cv-contacts a:hover { text-decoration: underline; }

      /* ── SECTIONS ── */
      section { margin-top: 18px; }
      h2 {
        font-size: 11.5pt;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        border-bottom: 1.5px solid var(--text);
        padding-bottom: 2px;
        margin-bottom: 10px;
      }

      /* ── EXPERIENCE ── */
      .exp { margin-bottom: 14px; }
      .exp-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 2px;
      }
      .exp-title { font-weight: 700; font-size: 10.5pt; }
      .exp-company { font-weight: 400; }
      .exp-meta { font-size: 9pt; color: var(--muted); font-family: system-ui, sans-serif; text-align: right; }
      .exp ul {
        margin-top: 4px;
        padding-left: 14px;
        list-style: disc;
      }
      .exp li { margin-bottom: 2px; font-size: 9.5pt; }

      /* ── SKILLS ── */
      .skills-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px 24px;
        font-size: 9.5pt;
      }
      .skill-row strong { font-weight: 700; }

      /* ── PROJECTS ── */
      .project { margin-bottom: 8px; font-size: 9.5pt; }
      .project-header { display: flex; justify-content: space-between; align-items: baseline; }
      .project a { font-weight: 700; color: var(--text); text-decoration: none; }
      .project a:hover { text-decoration: underline; }
      .project-year { font-size: 9pt; color: var(--muted); font-family: system-ui, sans-serif; }
      .project-desc { color: var(--muted); margin-top: 1px; }

      /* ── PRINT ── */
      @media print {
        body { padding: 0; font-size: 9.5pt; background: #fff; }
        .cv-page { box-shadow: none; padding: 0; }
        .print-btn { display: none !important; }
        @page { margin: 1.8cm 1.6cm; size: A4; }
        section { margin-top: 14px; }
        .exp { margin-bottom: 10px; }
      }
    </style>
  </head>
  <body>
    <div style="position:fixed;top:20px;left:20px;display:flex;gap:8px;z-index:99;">
      <a class="lang-btn" href="/" style="position:static;">← Site</a>
      <a class="lang-btn" href="/en/resume" style="position:static;">EN</a>
    </div>
    <button class="print-btn" onclick="window.print()">⬇ Baixar PDF</button>

    <div class="cv-page">

    <!-- Header -->
    <header class="cv-header">
      <p class="cv-name">Leonardo Basso</p>
      <div class="cv-contacts">
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <span>·</span>
        <a href="tel:+5535998794471">+55 35 99879 4471</a>
        <span>·</span>
        <a href={SITE.socials.linkedin}>linkedin.com/in/leojunioyuri</a>
        <span>·</span>
        <a href={SITE.socials.github}>github.com/leojunioyuri</a>
        <span>·</span>
        <a href={SITE.url}>leojunioyuri.github.io</a>
      </div>
    </header>

    <!-- Descrição -->
    <section>
      <h2>Descrição</h2>
      <p style="font-size:9.5pt;">
        Engenheiro de Software e Product Engineer com 4+ anos de experiência, formado em Ciência da Computação pela UFLA. Na Brendi, lidero a área de aquisição de consumidores, onde desenvolvi o MetaAds — sistema de tráfego pago autônomo com IA que levou de zero a 2.000+ restaurantes atendidos, com R$20M+ em vendas rastreadas e retorno médio de 10× sobre o investimento aos nossos clientes.
      </p>
    </section>

    <!-- Experiência -->
    <section>
      <h2>Experiência</h2>
      {experiences.map(exp => (
        <div class="exp">
          <div class="exp-header">
            <span class="exp-title">{exp.role} <span class="exp-company">· {exp.company}</span></span>
            <div class="exp-meta">
              <div>{exp.period}</div>
              <div>{exp.location}</div>
            </div>
          </div>
          <ul>
            {exp.bullets.map(b => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <!-- Formação -->
    <section>
      <h2>Formação</h2>
      <div class="exp">
        <div class="exp-header">
          <span class="exp-title">Bacharel em Ciência da Computação <span class="exp-company">· UFLA</span></span>
          <div class="exp-meta">
            <div>Ago 2018 — Dez 2023</div>
            <div>Lavras, MG</div>
          </div>
        </div>
        <ul>
          <li>Presidente do CIMVEST (2021): 1º núcleo de educação financeira da UFLA, cresceu de 10 para 40 membros, 1º Simpósio com 300+ espectadores.</li>
          <li>Tech Lead da Comp Júnior (2019–2021): liderança técnica em empresa júnior com cultura ágil.</li>
        </ul>
      </div>
    </section>

    <!-- Habilidades -->
    <section>
      <h2>Habilidades</h2>
      <div class="skills-grid">
        {skills.map(s => (
          <p class="skill-row"><strong>{s.label}:</strong> {s.items}</p>
        ))}
      </div>
    </section>

    <!-- Projetos -->
    <section>
      <h2>Projetos</h2>
      {projects.map(p => (
        <div class="project">
          <div class="project-header">
            <a href={p.url} target="_blank" rel="noopener noreferrer">{p.name}</a>
            <span class="project-year">{p.year}</span>
          </div>
          <p class="project-desc">{p.desc}</p>
        </div>
      ))}
    </section>

    </div> <!-- /cv-page -->
  </body>
</html>
