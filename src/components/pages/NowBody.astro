---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/consts";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items: Record<Lang, string[]> = {
  pt: [
    "Construindo e aprendendo sobre agents de IA para ser agências de tráfego pago para clientes — gerindo anúncios de ponta a ponta e trazendo aumento de vendas.",
    "Começando a escrever sobre os desafios e aprendizados do dia a dia em escalar um produto para milhares de usuários.",
    "Tentando encontrar tempo em tudo isso para colocar em dia minha lista de jogos, filmes e séries.",
  ],
  en: [
    "Building and learning about AI agents that act as paid-traffic agencies for clients — managing ads end to end and driving sales growth.",
    "Starting to write about the day-to-day challenges and lessons of scaling a product to thousands of users.",
    "Trying to find time in all of this to catch up on my backlog of games, films and series.",
  ],
};

const path = lang === "pt" ? "/now" : "/en/now";
const nowLabel = lang === "pt" ? "Inspirado na ideia de" : "Inspired by the";
const nowSuffix = lang === "pt" ? "." : " page idea.";
---

<BaseLayout
  lang={lang}
  title={t("now.title")}
  description={t("now.subtitle")}
  path={path}
>
  <section class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      {t("now.title")}
    </h1>
    <p class="mt-3 text-lg text-[var(--muted)]">{t("now.subtitle")}</p>
    <ul data-reveal-scroll class="mt-10 flex flex-col gap-4">
      {
        items[lang].map((i) => (
          <li class="flex items-start gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-5">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[var(--accent)]" />
            <span class="text-[var(--fg)]">{i}</span>
          </li>
        ))
      }
    </ul>
    <div data-reveal-scroll class="mt-10">
      <img
        src="/peterparkertryingbetter.gif"
        alt="Peter Parker — trying to do better"
        class="rounded-xl border border-[var(--border)] max-w-xs"
        loading="lazy"
      />
    </div>

    <p class="mt-8 text-sm text-[var(--muted)]">
      {nowLabel}{" "}
      <a
        href="https://nownownow.com/about"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--accent)] hover:underline">/now</a
      >{nowSuffix}
    </p>
  </section>
</BaseLayout>
