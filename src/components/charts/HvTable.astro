---
const rows = [
  { threshold: 'Toda a base',               n: 1115, pct: '100%',  roas: 9.31,  gmv: 'R$ 9,8M',  hl: false },
  { threshold: '≥ 300 pedidos org/90d',      n: 555,  pct: '49,8%', roas: 11.61, gmv: 'R$ 7,8M',  hl: false },
  { threshold: '≥ 600 org/90d  ← sweet spot', n: 395, pct: '35,4%', roas: 12.83, gmv: 'R$ 6,3M',  hl: true  },
  { threshold: '≥ 1.000 org/90d  (gate v3)', n: 252,  pct: '22,6%', roas: 13.94, gmv: 'R$ 4,7M',  hl: false },
  { threshold: '≥ 1.500 org/90d',            n: 176,  pct: '15,8%', roas: 14.59, gmv: 'R$ 3,4M',  hl: false },
];
---

<div class="not-prose my-6 overflow-hidden rounded-xl border border-[var(--border)]">
  <p class="border-b border-[var(--border)] bg-[var(--surface)] px-4 py-2.5 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
    HV Pre-Threshold — pedidos orgânicos 90d antes dos ads
  </p>
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;font-family:var(--font-mono);font-size:12px;">
      <thead>
        <tr style="background:var(--surface);">
          <th style="text-align:left;padding:8px 14px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;">Threshold</th>
          <th style="text-align:right;padding:8px 14px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;">Lojas</th>
          <th style="text-align:right;padding:8px 14px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;">% base</th>
          <th style="text-align:right;padding:8px 14px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;">ROAS</th>
          <th style="text-align:right;padding:8px 14px;border-bottom:1px solid var(--border);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);font-weight:500;">GMV</th>
        </tr>
      </thead>
      <tbody>
        {rows.map(r => (
          <tr style={r.hl ? 'background:var(--accent-soft);' : 'background:var(--bg);'}>
            <td style="padding:10px 14px;border-bottom:1px solid var(--border);color:var(--fg);">{r.threshold}</td>
            <td style="padding:10px 14px;border-bottom:1px solid var(--border);text-align:right;color:var(--muted);">{r.n}</td>
            <td style="padding:10px 14px;border-bottom:1px solid var(--border);text-align:right;color:var(--muted);">{r.pct}</td>
            <td style="padding:10px 14px;border-bottom:1px solid var(--border);text-align:right;">
              <span style={`font-weight:700;color:${r.roas >= 13 ? 'var(--accent)' : r.roas >= 11 ? 'var(--fg)' : 'var(--muted)'}`}>{r.roas.toFixed(2)}×</span>
            </td>
            <td style="padding:10px 14px;border-bottom:1px solid var(--border);text-align:right;color:var(--muted);">{r.gmv}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
