---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, type Lang } from "@/consts";
import { useTranslations, formatDate } from "@/i18n/utils";
import letterboxd from "@/data/letterboxd.json";
import { games as gameList } from "@/data/games";
import spotify from "@/data/spotify.json";
import steam from "@/data/steam.json";
import xbox from "@/data/xbox.json";
import youtube from "@/data/youtube.json";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const path = lang === "pt" ? "/life" : "/en/life";

const tracks = spotify.tracks ?? [];
const topTracks = (spotify as any).topTracks ?? [];
const topGames = (steam as any).topGames ?? [];
const steamWishlist = (steam as any).wishlist ?? [];

// Merge Steam recent + Xbox/PC recent, deduplicate by normalized name
function normName(n: string) {
  return n.toLowerCase().replace(/[™®©]/g, '').replace(/\s+/g, ' ').trim();
}
const steamRecent = (steam.games ?? []).map((g: any) => ({
  name: g.name, image: g.image, url: g.url, minutes2weeks: g.minutes2weeks,
  source: 'steam' as const, lastPlayed: null,
}));
const xboxRaw = (xbox.recent ?? []) as any[];
const xboxTopGamerscore = (xbox as any).topGamerscore ?? [];
const steamNames = new Set(steamRecent.map((g: any) => normName(g.name)));
const xboxOnly = xboxRaw.filter((g) => !steamNames.has(normName(g.name))).map((g) => ({
  name: g.name, image: g.image, url: g.url, minutes2weeks: 0,
  source: 'xbox' as const, lastPlayed: g.lastPlayed,
}));
const recentGames = [...steamRecent, ...xboxOnly];
const videos = youtube.videos ?? [];
const watched = letterboxd.watched ?? [];
const watchlist = letterboxd.watchlist ?? [];
const favorites = watched.filter((f: any) => f.rating === 5);
const playedGames = gameList.filter((g) => g.status === "played");
const wishGames = gameList.filter((g) => g.status === "wishlist");

/** Render a 0–5 rating as filled / half / empty stars. */
function stars(rating?: number): ("full" | "half" | "empty")[] {
  const r = rating ?? 0;
  return Array.from({ length: 5 }, (_, i) => {
    if (r >= i + 1) return "full";
    if (r >= i + 0.5) return "half";
    return "empty";
  });
}

const updated = spotify.updatedAt || steam.updatedAt || youtube.updatedAt;
---

<BaseLayout
  lang={lang}
  title={t("life.title")}
  description={t("life.subtitle")}
  path={path}
>
  <section class="mx-auto max-w-3xl px-5 py-20 sm:px-6">
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      {t("life.title")}
    </h1>
    <p class="mt-3 text-lg text-[var(--muted)]">{t("life.subtitle")}</p>
    {
      updated && (
        <p class="mt-2 text-xs text-[var(--muted)]">
          {t("life.updated")} {formatDate(new Date(updated), lang)}
        </p>
      )
    }

    {/* —— Música / Music —— */}
    <h2 data-reveal-scroll class="mt-16 text-xl font-bold tracking-tight">
      🎧 {t("life.music.title")}
    </h2>

    {/* Últimas ouvidas */}
    {tracks.length > 0 && (
      <div data-reveal-scroll>
        <h3 class="mt-5 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
          {t("life.music.recent")}
        </h3>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {tracks.slice(0, 4).map((tr: any) => (
            <li class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-3">
              {tr.image && (
                <img src={tr.image} alt="" width="40" height="40" loading="lazy"
                  class="h-10 w-10 rounded object-cover" />
              )}
              <span class="min-w-0">
                <a href={tr.url} target="_blank" rel="noopener noreferrer"
                  class="block truncate text-sm font-medium hover:text-[var(--accent)]">
                  {tr.name}
                </a>
                <span class="block truncate text-xs text-[var(--muted)]">{tr.artist}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Mais ouvidas — abas por período */}
    {(topTracks.short?.length > 0 || topTracks.medium?.length > 0 || topTracks.long?.length > 0) && (
      <div data-reveal-scroll class="mt-8">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
          {t("life.music.top")}
        </h3>
        <!-- Tab buttons -->
        <div class="mt-3 flex gap-1 rounded-lg border border-[var(--border)] bg-[var(--surface)] p-1 w-fit">
          {(['short','medium','long'] as const).map((range) => (
            <button
              data-music-tab={range}
              class:list={[
                'music-tab rounded-md px-3 py-1.5 text-xs font-medium transition-colors',
                range === 'short'
                  ? 'bg-[var(--bg)] text-[var(--fg)] shadow-sm'
                  : 'text-[var(--muted)] hover:text-[var(--fg)]'
              ]}
            >
              {range === 'short' ? t("life.music.tab.short") : range === 'medium' ? t("life.music.tab.medium") : t("life.music.tab.long")}
            </button>
          ))}
        </div>
        <!-- Tab panels -->
        {(['short','medium','long'] as const).map((range) => (
          <ul
            data-music-panel={range}
            class:list={['mt-3 grid gap-2 sm:grid-cols-2', range !== 'short' && 'hidden']}
          >
            {(topTracks[range] ?? []).map((tr: any) => (
              <li class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-3">
                <span class="shrink-0 w-5 text-center text-xs font-bold text-[var(--muted)]">{tr.rank}</span>
                {tr.image && (
                  <img src={tr.image} alt="" width="36" height="36" loading="lazy"
                    class="h-9 w-9 shrink-0 rounded object-cover" />
                )}
                <span class="min-w-0">
                  <a href={tr.url} target="_blank" rel="noopener noreferrer"
                    class="block truncate text-sm font-medium hover:text-[var(--accent)]">
                    {tr.name}
                  </a>
                  <span class="block truncate text-xs text-[var(--muted)]">{tr.artist}</span>
                </span>
              </li>
            ))}
          </ul>
        ))}
      </div>
    )}

    {tracks.length === 0 && topTracks.short?.length === 0 && (
      <p data-reveal-scroll class="mt-4 text-sm text-[var(--muted)]">{t("life.music.empty")}</p>
    )}

    {/* —— Jogos / Games —— */}
    <h2 data-reveal-scroll class="mt-14 text-xl font-bold tracking-tight">
      🎮 {t("life.games.title")}
    </h2>

    <h3
      data-reveal-scroll
      class="mt-5 text-xs font-semibold uppercase tracking-wide text-[var(--muted)]"
    >
      {t("life.games.recent")}
    </h3>
    {
      recentGames.length === 0 ? (
        <p data-reveal-scroll class="mt-3 text-sm text-[var(--muted)]">
          {t("life.games.empty")}
        </p>
      ) : (
        <ul data-reveal-scroll class="mt-3 grid gap-2 sm:grid-cols-2">
          {recentGames.map((g: any) => (
            <li class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-3">
              {g.image && (
                <img
                  src={g.image}
                  alt=""
                  width="32"
                  height="32"
                  loading="lazy"
                  class="h-8 w-8 rounded"
                />
              )}
              <span class="min-w-0">
                <a
                  href={g.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block truncate text-sm font-medium hover:text-[var(--accent)]"
                >
                  {g.name}
                </a>
                {g.minutes2weeks > 0 ? (
                  <span class="block text-xs text-[var(--muted)]">
                    {Math.round(g.minutes2weeks)} {t("life.minutes")}
                  </span>
                ) : g.lastPlayed ? (
                  <span class="block text-xs text-[var(--muted)]">
                    {new Date(g.lastPlayed).toLocaleDateString(lang === 'pt' ? 'pt-BR' : 'en', { month: 'short', day: 'numeric' })}
                  </span>
                ) : null}
              </span>
            </li>
          ))}
        </ul>
      )
    }
    <p class="mt-2 text-xs text-[var(--muted)]">{t("life.games.note")}</p>

    {topGames.length > 0 && (
      <div data-reveal-scroll class="mt-8">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
          {t("life.games.top")}
        </h3>
        <ul class="mt-3 grid gap-2">
          {topGames.map((g: any) => (
            <li class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-3">
              {g.image && (
                <img src={g.image} alt="" width="32" height="32" loading="lazy"
                  class="h-8 w-8 rounded" />
              )}
              <a href={g.url} target="_blank" rel="noopener noreferrer"
                class="min-w-0 flex-1 truncate text-sm font-medium hover:text-[var(--accent)]">
                {g.name}
              </a>
              <span class="shrink-0 text-xs text-[var(--muted)]">
                {Math.round(g.minutesTotal / 60)}h
              </span>
            </li>
          ))}
        </ul>
      </div>
    )}
    {SITE.links.steam && (
      <a
        href={SITE.links.steam}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex text-sm font-semibold text-[var(--accent)] hover:underline"
      >
        {t("life.games.steam")} →
      </a>
    )}

    {
      playedGames.length > 0 && (
        <div data-reveal-scroll class="mt-8">
          <h3 class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
            {t("life.games.played")}
          </h3>
          <ul class="mt-3 grid gap-2">
            {playedGames.map((g) => (
              <li class="flex flex-wrap items-baseline gap-x-3 gap-y-1 rounded-lg border border-[var(--border)] bg-[var(--surface)] px-4 py-2.5">
                <span class="font-medium">
                  {g.favorite && <span class="text-[var(--accent)]">♥ </span>}
                  {g.title}
                </span>
                {g.platform && (
                  <span class="text-xs text-[var(--muted)]">{g.platform}</span>
                )}
                <span
                  class="ml-auto whitespace-nowrap text-sm"
                  aria-label={`${g.rating ?? 0}/5`}
                >
                  {stars(g.rating).map((s) => (
                    <span
                      class={
                        s === "empty"
                          ? "text-[var(--border)]"
                          : "text-[var(--accent)]"
                      }
                    >
                      {s === "half" ? "⯪" : "★"}
                    </span>
                  ))}
                </span>
                {g.note && (
                  <span class="w-full text-xs text-[var(--muted)]">{g.note}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      )
    }
    {steamWishlist.length > 0 && (
      <div data-reveal-scroll class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
          {t("life.games.wishlist")}
        </h3>
        <ul class="mt-3 grid gap-2 sm:grid-cols-2">
          {steamWishlist.map((g: any) => (
            <li>
              <a
                href={g.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)] transition-colors hover:border-[var(--accent)]"
              >
                {g.header && (
                  <img
                    src={g.header}
                    alt=""
                    loading="lazy"
                    class="h-12 w-[88px] shrink-0 object-cover"
                  />
                )}
                <span class="truncate pr-3 text-sm font-medium group-hover:text-[var(--accent)]">
                  {g.name}
                </span>
              </a>
            </li>
          ))}
        </ul>
        <a
          href={`https://store.steampowered.com/wishlist/profiles/76561198115976638/`}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex text-sm font-semibold text-[var(--accent)] hover:underline"
        >
          {t("life.games.wishlist.cta")} →
        </a>
      </div>
    )}


    {/* —— Xbox top gamerscore —— */}
    {xboxTopGamerscore.length > 0 && (
      <div data-reveal-scroll class="mt-8">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">
          {t("life.xbox.top")}
        </h3>
        <ul class="mt-3 grid gap-2">
          {xboxTopGamerscore.slice(0, 6).map((g: any) => (
            <li class="flex items-center gap-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-3">
              {g.image ? (
                <img src={g.image} alt="" width="32" height="32" loading="lazy"
                  class="h-8 w-8 shrink-0 rounded object-cover" />
              ) : (
                <div class="h-8 w-8 shrink-0 rounded bg-[var(--surface-2)]"/>
              )}
              <a href={g.url} target="_blank" rel="noopener noreferrer"
                class="min-w-0 flex-1 truncate text-sm font-medium hover:text-[var(--accent)]">
                {g.name}
              </a>
              <span class="shrink-0 text-xs text-[var(--muted)] tabular-nums">
                {g.gamerscore}<span class="text-[var(--border)]">/{g.gamerscoreTotal}</span>G
              </span>
            </li>
          ))}
        </ul>
        <div class="mt-4 flex flex-wrap items-center gap-4">
          {xboxTopGamerscore.length > 6 && (
            <button
              id="xbox-dialog-btn"
              class="text-sm font-semibold text-[var(--accent)] hover:underline"
            >
              {lang === 'pt' ? `Ver todos os ${xboxTopGamerscore.length} jogos →` : `See all ${xboxTopGamerscore.length} games →`}
            </button>
          )}
          <a
            href="https://www.xbox.com/pt-BR/play/user/Leonardo%20Yuri"
            target="_blank" rel="noopener noreferrer"
            class="text-sm font-semibold text-[var(--accent)] hover:underline"
          >
            {t("life.xbox.cta")} →
          </a>
        </div>
      </div>
    )}

    <!-- Xbox full games dialog -->
    {xboxTopGamerscore.length > 6 && (
      <dialog
        id="xbox-dialog"
        class="m-auto w-full max-w-lg rounded-2xl border border-[var(--border)] bg-[var(--bg)] p-0 shadow-2xl backdrop:bg-black/50"
      >
        <div class="flex items-center justify-between border-b border-[var(--border)] px-5 py-4">
          <h2 class="text-base font-bold">{t("life.xbox.top")} ({xboxTopGamerscore.length})</h2>
          <button id="xbox-dialog-close" class="rounded-lg p-1 hover:bg-[var(--surface)] text-[var(--muted)]" aria-label="Fechar">✕</button>
        </div>
        <ul class="max-h-[60vh] overflow-y-auto divide-y divide-[var(--border)]">
          {xboxTopGamerscore.map((g: any) => (
            <li class="flex items-center gap-3 px-5 py-3 hover:bg-[var(--surface)]">
              {g.image ? (
                <img src={g.image} alt="" width="28" height="28" loading="lazy"
                  class="h-7 w-7 shrink-0 rounded" />
              ) : (
                <div class="h-7 w-7 shrink-0 rounded bg-[var(--surface-2)]"/>
              )}
              <a href={g.url} target="_blank" rel="noopener noreferrer"
                class="min-w-0 flex-1 truncate text-sm hover:text-[var(--accent)]">
                {g.name}
              </a>
              <span class="shrink-0 text-xs text-[var(--muted)] tabular-nums">
                {g.gamerscore}<span class="opacity-40">/{g.gamerscoreTotal}</span>G
              </span>
            </li>
          ))}
        </ul>
      </dialog>
    )}

    {/* —— YouTube —— */}
    <h2 data-reveal-scroll class="mt-14 text-xl font-bold tracking-tight">
      📺 {t("life.video.title")}
    </h2>
    {
      videos.length === 0 ? (
        <p data-reveal-scroll class="mt-4 text-sm text-[var(--muted)]">
          {t("life.video.empty")}{" "}
          {SITE.links.youtube && (
            <a
              href={SITE.links.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-[var(--accent)] hover:underline"
            >
              {t("life.video.cta")} →
            </a>
          )}
        </p>
      ) : (
        <ul data-reveal-scroll class="mt-4 grid gap-3 sm:grid-cols-3">
          {videos.map((v: any) => (
            <li class="overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--surface)]">
              <a href={v.url} target="_blank" rel="noopener noreferrer">
                {v.thumbnail && (
                  <img
                    src={v.thumbnail}
                    alt=""
                    loading="lazy"
                    class="aspect-video w-full object-cover"
                  />
                )}
                <span class="block p-3 text-sm font-medium hover:text-[var(--accent)]">
                  {v.title}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {SITE.links.youtube && (
      <a
        href={SITE.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-flex text-sm font-semibold text-[var(--accent)] hover:underline"
      >
        {t("life.video.cta")} →
      </a>
    )}

    {/* —— Filmes favoritos / Favorite films —— */}
    <h2 data-reveal-scroll class="mt-14 text-xl font-bold tracking-tight">
      🎬 {t("life.films.title")}
    </h2>
    {
      favorites.length === 0 ? (
        <p class="mt-4 text-sm text-[var(--muted)]">{t("life.films.empty")}</p>
      ) : (
        <ul data-reveal-scroll class="mt-5 grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6">
          {favorites.map((f: any) => (
            <li>
              <a
                href={f.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative block aspect-[2/3] overflow-hidden rounded-lg border border-[var(--border)] transition-transform hover:-translate-y-1 hover:border-[var(--accent)]"
                title={`${f.title}${f.year ? ` (${f.year})` : ''}`}
              >
                {f.poster ? (
                  <img
                    src={f.poster}
                    alt={f.title}
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="h-full w-full flex items-center justify-center bg-[var(--surface-2)] text-xs text-[var(--muted)] p-2 text-center leading-snug">
                    {f.title}
                  </div>
                )}
                <!-- Hover overlay with title -->
                <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/80 via-black/20 to-transparent p-2 opacity-0 transition-opacity group-hover:opacity-100">
                  <p class="text-xs font-semibold leading-snug text-white">{f.title}</p>
                  {f.year && <p class="text-xs text-white/70">{f.year}</p>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
    {
      SITE.links.imdb && (
        <a
          href={SITE.links.imdb}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex text-sm font-semibold text-[var(--accent)] hover:underline"
        >
          {t("life.films.imdb")} →
        </a>
      )
    }
  </section>
</BaseLayout>

<script>
  // Music tabs
  const musicTabs   = document.querySelectorAll<HTMLButtonElement>('[data-music-tab]');
  const musicPanels = document.querySelectorAll<HTMLElement>('[data-music-panel]');
  musicTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const range = tab.dataset.musicTab!;
      musicTabs.forEach((t) => t.classList.toggle('bg-[var(--bg)]', t.dataset.musicTab === range));
      musicTabs.forEach((t) => t.classList.toggle('shadow-sm', t.dataset.musicTab === range));
      musicTabs.forEach((t) => t.classList.toggle('text-[var(--fg)]', t.dataset.musicTab === range));
      musicTabs.forEach((t) => t.classList.toggle('text-[var(--muted)]', t.dataset.musicTab !== range));
      musicPanels.forEach((p) => p.classList.toggle('hidden', p.dataset.musicPanel !== range));
    });
  });

  // Xbox dialog
  const btn   = document.getElementById('xbox-dialog-btn');
  const dlg   = document.getElementById('xbox-dialog') as HTMLDialogElement | null;
  const close = document.getElementById('xbox-dialog-close');
  btn?.addEventListener('click', () => dlg?.showModal());
  close?.addEventListener('click', () => dlg?.close());
  dlg?.addEventListener('click', (e) => { if (e.target === dlg) dlg.close(); });
</script>
